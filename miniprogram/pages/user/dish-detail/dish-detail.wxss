.detail-page {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
  background: #211815;
  color: #fffaf4;
}

.detail-background {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, #281a14 0%, #3a281f 48%, #efe5da 76%, #f7f2ec 100%);
}

.background-glow {
  position: absolute;
  top: 520rpx;
  right: -120rpx;
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  background: rgba(205, 128, 67, 0.22);
  filter: blur(70rpx);
}

.hero-section {
  position: relative;
  height: 480rpx;
  overflow: hidden;
  background: radial-gradient(circle at 62% 42%, #c98542, #6e3c21 56%, #28160f 100%);
}

.hero-image-window,
.hero-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  overflow: hidden;
}

.hero-image {
  position: absolute;
  max-width: none;
}

.hero-shade {
  background: linear-gradient(180deg, rgba(22, 13, 9, 0.4) 0%, rgba(25, 14, 9, 0.04) 34%, rgba(28, 16, 11, 0.22) 62%, rgba(31, 20, 15, 0.94) 100%);
}

.custom-nav {
  position: relative;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: content-box;
  padding-right: 30rpx;
  padding-left: 30rpx;
}

.back-button,
.nav-placeholder {
  width: 62rpx;
  height: 62rpx;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  background: rgba(24, 16, 12, 0.54);
  color: #ffffff;
  font-family: serif;
  font-size: 50rpx;
  line-height: 1;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.12);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.nav-title {
  color: #f4d9a5;
  font-family: serif;
  font-size: 30rpx;
  font-weight: bold;
  letter-spacing: 3rpx;
}

.hero-caption {
  position: absolute;
  z-index: 3;
  right: 34rpx;
  bottom: 34rpx;
  left: 34rpx;
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 15rpx;
  border: 1rpx solid rgba(241, 197, 127, 0.34);
  border-radius: 999rpx;
  background: rgba(46, 29, 20, 0.54);
  color: #f2d29a;
  font-size: 18rpx;
  -webkit-backdrop-filter: blur(16rpx);
  backdrop-filter: blur(16rpx);
}

.hero-kicker text {
  width: 12rpx;
  height: 12rpx;
  margin-right: 9rpx;
  border-radius: 50%;
  background: #74dc54;
  box-shadow: 0 0 12rpx rgba(116, 220, 84, 0.72);
}

.detail-content {
  position: relative;
  z-index: 4;
  margin-top: -18rpx;
  padding: 0 24rpx;
}

.glass-panel {
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  background: rgba(62, 47, 39, 0.78);
  box-shadow: 0 18rpx 42rpx rgba(27, 17, 12, 0.2), inset 0 2rpx 0 rgba(255, 255, 255, 0.1);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.warm-glass {
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  background: rgba(255, 250, 244, 0.9);
  color: #2b201a;
  box-shadow: 0 16rpx 38rpx rgba(61, 39, 25, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.dish-panel,
.ingredient-panel,
.quantity-panel {
  box-sizing: border-box;
  border-radius: 32rpx;
}

.dish-panel {
  padding: 22rpx 24rpx 20rpx;
}

.dish-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.dish-title-wrap {
  min-width: 0;
  flex: 1;
}

.dish-name {
  color: #fffdf8;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1.22;
}

.dish-subtitle,
.section-kicker {
  margin-top: 4rpx;
  color: #cba96f;
  font-size: 14rpx;
  letter-spacing: 2rpx;
}

.dish-price {
  flex: none;
  color: #ff5055;
  font-size: 34rpx;
  font-weight: bold;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.dish-tag {
  padding: 5rpx 10rpx;
  border: 1rpx solid rgba(255, 103, 101, 0.22);
  border-radius: 10rpx;
  background: rgba(206, 48, 45, 0.16);
  color: #ff918d;
  font-size: 18rpx;
}

.dish-tag.sold-out-tag {
  border-color: rgba(216, 121, 24, 0.28);
  background: rgba(255, 241, 221, 0.18);
  color: #ffd3a0;
  font-weight: bold;
}

.dish-description {
  display: -webkit-box;
  margin-top: 14rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  line-height: 1.55;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.fresh-note {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.58);
  font-size: 18rpx;
}

.fresh-note text {
  width: 11rpx;
  height: 11rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #ed3d43;
}

.ingredient-panel,
.quantity-panel {
  margin-top: 12rpx;
  padding: 18rpx 22rpx;
}

.section-head,
.quantity-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-kicker {
  margin-top: 0;
  color: #b38145;
}

.section-kicker.is-light {
  color: #d4af73;
}

.section-title,
.quantity-title {
  margin-top: 3rpx;
  font-size: 25rpx;
  font-weight: bold;
}

.section-note,
.quantity-desc {
  color: #917c6e;
  font-size: 18rpx;
}

.ingredient-list {
  display: flex;
  flex-wrap: nowrap;
  gap: 8rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.ingredient-item {
  flex: none;
  display: flex;
  align-items: center;
  padding: 8rpx 11rpx;
  border: 1rpx solid rgba(119, 83, 55, 0.1);
  border-radius: 999rpx;
  background: rgba(232, 218, 204, 0.58);
  color: #665448;
  font-size: 18rpx;
}

.ingredient-dot {
  width: 8rpx;
  height: 8rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: #e63b4a;
}

.quantity-title {
  color: #fffdf8;
}

.quantity-desc {
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.55);
}

.stepper {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.stepper-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 50%;
  background: linear-gradient(145deg, #f04449, #bd101a);
  color: #ffffff;
  font-size: 29rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 18rpx rgba(184, 13, 22, 0.34), inset 0 2rpx 2rpx rgba(255, 255, 255, 0.3);
}

.stepper-button.is-minus {
  background: rgba(255, 255, 255, 0.1);
  box-shadow: none;
}

.stepper-button.is-disabled {
  color: rgba(255, 255, 255, 0.38);
  background: rgba(255, 255, 255, 0.1);
  box-shadow: none;
}

.stepper-value {
  min-width: 34rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: bold;
  text-align: center;
}

.detail-spacer {
  height: calc(136rpx + env(safe-area-inset-bottom));
}

.purchase-bar {
  position: fixed;
  z-index: 30;
  right: 24rpx;
  bottom: calc(14rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  display: flex;
  align-items: center;
  min-height: 92rpx;
  box-sizing: border-box;
  padding: 9rpx 10rpx 9rpx 18rpx;
  border-radius: 42rpx;
  background: rgba(53, 43, 37, 0.9);
}

.purchase-summary {
  min-width: 128rpx;
}

.purchase-label {
  color: rgba(255, 255, 255, 0.52);
  font-size: 18rpx;
}

.purchase-price {
  margin-top: 2rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}

.purchase-count {
  min-width: 60rpx;
  flex: 1;
  padding-left: 14rpx;
  border-left: 1rpx solid rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.56);
  font-size: 18rpx;
}

.add-cart-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 250rpx;
  height: 68rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 999rpx;
  background: linear-gradient(145deg, #f5474c, #c5121c);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: bold;
  line-height: 68rpx;
  box-shadow: 0 10rpx 24rpx rgba(181, 9, 17, 0.38), inset 0 2rpx 2rpx rgba(255, 255, 255, 0.34);
}

.add-cart-button::after {
  border: 0;
}

.add-cart-button text {
  margin-left: 14rpx;
  font-size: 34rpx;
  font-weight: normal;
}

.add-cart-button.is-disabled {
  background: linear-gradient(145deg, #d8cec4, #a99a8e);
  color: rgba(255, 255, 255, 0.86);
  box-shadow: none;
}
