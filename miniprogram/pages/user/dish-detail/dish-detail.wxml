<view class="detail-page">
  <view class="detail-background">
    <view class="background-glow"></view>
  </view>

  <view class="hero-section">
    <view class="hero-image-window">
      <image
        wx:if="{{imageAvailable}}"
        class="hero-image {{dish.is_placeholder_image ? 'is-placeholder' : ''}}"
        src="{{dish.image}}"
        style="{{dish.image_style}}"
        mode="{{dish.image_mode}}"
        binderror="handleImageError"
      ></image>
    </view>
    <view class="hero-shade"></view>

    <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navigationHeight}}px;">
      <view class="back-button" bindtap="goBack"><image class="nav-icon-image" src="/images/icons/icon-back.svg" mode="aspectFit"></image></view>
      <view class="nav-title">餐品详情</view>
      <view class="nav-placeholder"></view>
    </view>

    <view class="hero-caption">
      <view class="hero-kicker"><text></text>现炒现做 · 热气上桌</view>
    </view>
  </view>

  <view class="detail-content">
    <view wx:if="{{pageStatus === 'error'}}" class="detail-error-card glass-panel">
      <view class="error-mark"><image class="state-icon-image" src="/images/icons/icon-warning.svg" mode="aspectFit"></image></view>
      <view class="error-title">{{errorTitle}}</view>
      <view class="error-desc">{{errorMessage}}</view>
      <view class="error-actions">
        <button wx:if="{{canRetry}}" class="error-button secondary" bindtap="retryLoad">重新加载</button>
        <button class="error-button primary" bindtap="goToMenu">返回菜单</button>
      </view>
    </view>

    <view wx:if="{{pageStatus !== 'error'}}" class="dish-panel glass-panel">
      <view class="dish-head">
        <view class="dish-title-wrap">
          <view class="dish-name">{{pageStatus === 'loading' ? '餐品加载中' : dish.name}}</view>
          <view class="dish-subtitle">SAN YE SIGNATURE</view>
        </view>
        <view class="dish-price">{{pageStatus === 'loading' ? '¥--' : unitPriceText}}</view>
      </view>

      <view wx:if="{{pageStatus !== 'loading'}}" class="tag-row">
        <view wx:if="{{dish.is_sold_out}}" class="dish-tag sold-out-tag">已售罄</view>
        <view wx:for="{{dish.tags}}" wx:key="*this" class="dish-tag">{{item}}</view>
      </view>

      <view class="dish-description">{{pageStatus === 'loading' ? '正在读取餐品详情，请稍等。' : dish.description}}</view>
      <view class="fresh-note"><text></text>{{statusNotice}}</view>
    </view>

    <view wx:if="{{pageStatus !== 'error' && specGroups.length}}" class="option-panel glass-panel">
      <view class="option-panel-head">
        <view>
          <view class="section-kicker is-light">SPEC</view>
          <view class="option-panel-title">选择规格</view>
        </view>
        <view class="option-panel-note">单选</view>
      </view>
      <view wx:for="{{specGroups}}" wx:key="group_id" wx:for-item="group" class="option-group">
        <view class="option-group-head">
          <view class="option-group-title">{{group.name}}</view>
          <view wx:if="{{group.required}}" class="option-required">必选</view>
        </view>
        <view class="option-chip-list">
          <view
            wx:for="{{group.options}}"
            wx:key="option_id"
            wx:for-item="option"
            class="option-chip {{option.is_selected ? 'is-selected' : ''}}"
            data-group-id="{{group.group_id}}"
            data-option-id="{{option.option_id}}"
            bindtap="selectSpecOption"
          >
            <text>{{option.name}}</text>
            <text wx:if="{{option.price_delta_cent > 0}}" class="option-price">{{option.price_delta_text}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{pageStatus !== 'error' && addonGroups.length}}" class="option-panel warm-glass">
      <view class="option-panel-head">
        <view>
          <view class="section-kicker">ADD-ONS</view>
          <view class="option-panel-title is-dark">加料选择</view>
        </view>
        <view class="option-panel-note is-dark">可多选</view>
      </view>
      <view wx:for="{{addonGroups}}" wx:key="group_id" wx:for-item="group" class="option-group">
        <view class="option-group-head">
          <view class="option-group-title is-dark">{{group.name}}</view>
          <view class="option-required is-dark">最多 {{group.max_select}} 项</view>
        </view>
        <view class="option-chip-list">
          <view
            wx:for="{{group.options}}"
            wx:key="option_id"
            wx:for-item="option"
            class="option-chip is-light-chip {{option.is_selected ? 'is-selected' : ''}}"
            data-group-id="{{group.group_id}}"
            data-option-id="{{option.option_id}}"
            bindtap="toggleAddonOption"
          >
            <text>{{option.name}}</text>
            <text wx:if="{{option.price_delta_cent > 0}}" class="option-price">{{option.price_delta_text}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{pageStatus !== 'error'}}" class="ingredient-panel warm-glass">
      <view class="section-head">
        <view>
          <view class="section-kicker">INGREDIENTS</view>
          <view class="section-title">主要食材</view>
        </view>
        <view class="section-note">每日新鲜备料</view>
      </view>
      <view class="ingredient-list">
        <view wx:for="{{dish.ingredients}}" wx:key="*this" class="ingredient-item">
          <text class="ingredient-dot"></text>
          <view>{{item}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{pageStatus !== 'error'}}" class="quantity-panel glass-panel">
      <view>
        <view class="section-kicker is-light">QUANTITY</view>
        <view class="quantity-title">选择数量</view>
        <view class="quantity-desc">按你的胃口来，至少选择一份</view>
      </view>
      <view class="stepper">
        <view class="stepper-button is-minus {{quantity === 1 ? 'is-disabled' : ''}}" bindtap="decreaseQuantity">−</view>
        <view class="stepper-value">{{quantity}}</view>
        <view class="stepper-button {{dish.is_sold_out ? 'is-disabled' : ''}}" bindtap="increaseQuantity">＋</view>
      </view>
    </view>

    <view wx:if="{{pageStatus !== 'error'}}" class="detail-spacer"></view>
  </view>

  <view wx:if="{{pageStatus !== 'error'}}" class="purchase-bar glass-panel">
    <view class="purchase-summary">
      <view class="purchase-label">合计</view>
      <view class="purchase-price">{{pageStatus === 'loading' ? '¥--' : totalPriceText}}</view>
    </view>
    <view class="purchase-count">{{quantity}} 份</view>
    <button class="add-cart-button {{pageStatus !== 'success' || dish.is_sold_out ? 'is-disabled' : ''}}" bindtap="addToCart" disabled="{{pageStatus !== 'success'}}">{{dish.is_sold_out ? '已售罄' : '加入购物车'}}<text wx:if="{{!dish.is_sold_out}}">›</text></button>
  </view>
</view>
