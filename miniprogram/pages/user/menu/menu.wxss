.dish-description,
.fallback-desc {
  -webkit-line-clamp: 2;
}

.empty-dishes {
  box-sizing: border-box;
  margin: 8rpx 2rpx 0;
  border: 1rpx solid rgba(112, 87, 69, 0.1);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.46);
}

.empty-emblem {
  font-weight: bold;
  box-shadow: inset 0 0 0 1rpx rgba(230, 59, 74, 0.08);
}

.empty-action,
.fallback-retry,
.checkout-button {
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.sold-out-badge,
.dish-tag.sold-out-tag {
  border-radius: 999rpx;
  font-weight: bold;
}

.nav-icon-image,
.search-icon-image,
.empty-icon-image,
.cart-icon-image,
.tab-icon-image {
  display: block;
}

.nav-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.search-icon-image {
  width: 28rpx;
  height: 28rpx;
}

.empty-icon-image {
  width: 54rpx;
  height: 54rpx;
}

.cart-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.tab-icon {
  width: 46rpx;
  height: 38rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.tab-icon-image {
  width: 36rpx;
  height: 36rpx;
}

.tab-item.is-active .tab-icon {
  border-color: transparent;
  background: transparent;
  color: #d82e36;
  box-shadow: none;
}
