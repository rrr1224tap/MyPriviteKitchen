.menu-page {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background: #f6eee4;
  color: #2a211d;
}

.menu-background,
.background-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
}

.background-food-window {
  position: absolute;
  top: -180rpx;
  right: -250rpx;
  width: 760rpx;
  height: 820rpx;
  overflow: hidden;
  opacity: 0.18;
  filter: blur(14rpx);
}

.background-food {
  position: absolute;
  top: -110rpx;
  left: -230rpx;
  width: 920rpx;
  max-width: none;
}

.background-shade {
  background:
    radial-gradient(circle at 78% 10%, rgba(255, 224, 188, 0.72), transparent 430rpx),
    radial-gradient(circle at 10% 4%, rgba(255, 255, 255, 0.78), transparent 360rpx),
    linear-gradient(180deg, #fbf2e8 0%, #f7efe6 42%, #f3e8dc 100%);
}

.dark-glass {
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  background: rgba(255, 251, 246, 0.72);
  box-shadow: 0 18rpx 42rpx rgba(91, 60, 39, 0.1), inset 0 2rpx 0 rgba(255, 255, 255, 0.92);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.custom-nav {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: content-box;
  padding-right: 30rpx;
  padding-left: 30rpx;
}

.back-button,
.nav-placeholder {
  width: 58rpx;
  height: 58rpx;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 50%;
  background: rgba(255, 250, 244, 0.82);
  color: #342620;
  font-family: serif;
  font-size: 47rpx;
  line-height: 1;
}

.nav-title {
  color: #2a211d;
  font-family: serif;
  font-size: 31rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.menu-header {
  position: relative;
  z-index: 5;
  padding: 18rpx 26rpx 0;
}

.shop-panel {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 164rpx;
  box-sizing: border-box;
  padding: 24rpx 178rpx 24rpx 28rpx;
  overflow: hidden;
  border-radius: 34rpx;
}

.shop-copy {
  min-width: 0;
  flex: 1;
}

.shop-name {
  font-size: 39rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: #2a211d;
}

.shop-branch {
  display: inline-block;
  margin-top: 7rpx;
  color: #8b7568;
  font-size: 20rpx;
}

.shop-status {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  color: #6b5b50;
  font-size: 21rpx;
}

.shop-status text {
  width: 13rpx;
  height: 13rpx;
  margin-right: 9rpx;
  border-radius: 50%;
  background: #65cf42;
  box-shadow: 0 0 14rpx rgba(101, 207, 66, 0.74);
}

.shop-notice {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 8rpx 14rpx;
  border: 1rpx solid rgba(255, 122, 50, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 246, 232, 0.82);
  color: #9a6a31;
  font-size: 18rpx;
}

.shop-photo {
  position: absolute;
  top: 18rpx;
  right: 26rpx;
  width: 134rpx;
  height: 134rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  background: #fff4e8;
  box-shadow: 0 12rpx 28rpx rgba(116, 77, 50, 0.16);
}

.shop-photo-source {
  position: absolute;
  top: -115rpx;
  left: -300rpx;
  width: 600rpx;
  max-width: none;
}

.search-button {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 50%;
  background: rgba(255, 250, 244, 0.88);
  color: #ef3e44;
  font-size: 18rpx;
  font-weight: bold;
}

.member-banner {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  box-sizing: border-box;
  margin-top: 14rpx;
  padding: 14rpx 20rpx;
  border-radius: 26rpx;
}

.member-crown {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  flex: none;
  border: 1rpx solid #ddb36d;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(225, 177, 101, 0.38), rgba(68, 44, 27, 0.32));
  color: #f1cc89;
  font-family: serif;
  font-size: 19rpx;
  font-weight: bold;
  box-shadow: 0 0 22rpx rgba(225, 177, 101, 0.26);
}

.member-copy {
  min-width: 0;
  flex: 1;
  margin-left: 17rpx;
}

.member-title {
  font-size: 24rpx;
  font-weight: bold;
}

.member-title text {
  margin-right: 8rpx;
  color: #f2cb86;
}

.member-desc {
  margin-top: 5rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 19rpx;
}

.member-action {
  display: flex;
  align-items: center;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffe4aa, #e6ae57);
  color: #432a16;
  font-size: 22rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(228, 172, 81, 0.26);
}

.member-action text {
  margin-left: 8rpx;
  font-size: 32rpx;
  line-height: 1;
}

.promo-banner {
  position: relative;
  height: 184rpx;
  margin-top: 14rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 116, 108, 0.32);
  border-radius: 30rpx;
  background: linear-gradient(110deg, #9f1416, #5f0a0a 58%, #25100c);
  box-shadow: 0 18rpx 40rpx rgba(91, 3, 6, 0.38), inset 0 2rpx 0 rgba(255, 255, 255, 0.11);
}

.promo-copy {
  position: relative;
  z-index: 4;
  width: 410rpx;
  padding: 21rpx 0 0 26rpx;
}

.promo-kicker {
  color: rgba(255, 255, 255, 0.76);
  font-size: 15rpx;
  letter-spacing: 2rpx;
}

.promo-title {
  margin-top: 2rpx;
  font-family: serif;
  font-size: 38rpx;
  font-weight: bold;
}

.promo-desc {
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 19rpx;
}

.promo-button {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 9rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ef3d42, #b51018);
  font-size: 19rpx;
  font-weight: bold;
  box-shadow: inset 0 2rpx 1rpx rgba(255, 255, 255, 0.25);
}

.promo-button text {
  margin-left: 8rpx;
  font-size: 27rpx;
  line-height: 1;
}

.promo-food-window {
  position: absolute;
  top: 0;
  right: 0;
  width: 350rpx;
  height: 184rpx;
  overflow: hidden;
  background: radial-gradient(circle at 68% 42%, #d94f31, #8a1715 56%, #32100c 100%);
}

.promo-food-source {
  position: absolute;
  top: -412rpx;
  left: -410rpx;
  width: 750rpx;
  max-width: none;
}

.promo-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(132, 11, 15, 0.98) 0%, rgba(132, 11, 15, 0.76) 49%, rgba(44, 10, 8, 0.02) 82%);
}

.promo-dots {
  position: absolute;
  z-index: 4;
  right: 330rpx;
  bottom: 13rpx;
  display: flex;
  gap: 10rpx;
}

.promo-dots text {
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.46);
}

.promo-dots .is-active {
  width: 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.fallback-notice {
  position: relative;
  z-index: 6;
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  margin: 12rpx 26rpx -4rpx;
  padding: 16rpx 18rpx 16rpx 22rpx;
  border-radius: 24rpx;
}

.fallback-copy {
  min-width: 0;
  flex: 1;
}

.fallback-title {
  color: #2a211d;
  font-size: 22rpx;
  font-weight: bold;
}

.fallback-desc {
  margin-top: 4rpx;
  color: #7c6a5f;
  font-size: 18rpx;
  line-height: 1.35;
}

.fallback-retry {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 52rpx;
  flex: none;
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff5b4d, #ef333b);
  color: #ffffff;
  font-size: 21rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 18rpx rgba(183, 8, 16, 0.28), inset 0 2rpx 2rpx rgba(255, 255, 255, 0.3);
}

.menu-body {
  position: relative;
  z-index: 5;
  display: flex;
  height: calc(100vh - 344rpx - env(safe-area-inset-bottom));
  min-height: 620rpx;
  margin: 20rpx 22rpx 0;
  overflow: hidden;
  border-radius: 34rpx;
  border-color: rgba(255, 255, 255, 0.82);
  background: rgba(255, 251, 246, 0.78);
  box-shadow: 0 18rpx 44rpx rgba(91, 60, 39, 0.1), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
}

.category-list {
  width: 172rpx;
  height: 100%;
  flex: none;
  box-sizing: border-box;
  padding: 14rpx 10rpx;
  border-right: 1rpx solid rgba(151, 119, 94, 0.08);
  background: linear-gradient(180deg, rgba(255, 250, 244, 0.6), rgba(250, 239, 228, 0.72));
}

.category-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  box-sizing: border-box;
  flex-direction: column;
  margin-bottom: 10rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid transparent;
  border-radius: 24rpx;
  color: #7e6b60;
  font-size: 21rpx;
  text-align: center;
}

.category-item.is-active {
  border-color: rgba(239, 62, 68, 0.12);
  background: linear-gradient(135deg, rgba(255, 244, 240, 0.98), rgba(255, 252, 248, 0.92));
  color: #ef333b;
  font-weight: bold;
  text-shadow: none;
  box-shadow: 0 10rpx 22rpx rgba(203, 73, 49, 0.1);
}

.category-mark {
  position: absolute;
  left: 8rpx;
  width: 7rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: transparent;
}

.category-item.is-active .category-mark {
  background: #ef333b;
  box-shadow: 0 8rpx 16rpx rgba(239, 51, 59, 0.26);
}

.category-badge {
  margin-top: 7rpx;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  background: #69b64d;
  color: #ffffff;
  font-size: 14rpx;
}

.dish-list {
  min-width: 0;
  height: 100%;
  flex: 1;
  box-sizing: border-box;
  padding: 24rpx 20rpx 0;
}

.dish-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 6rpx 20rpx;
}

.dish-section-title {
  color: #2a201b;
  font-size: 30rpx;
  font-weight: bold;
}

.dish-section-subtitle,
.dish-section-count {
  color: #9a887b;
  font-size: 18rpx;
}

.dish-section-subtitle {
  margin-top: 3rpx;
}

.dish-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dish-card {
  display: flex;
  min-height: 220rpx;
  box-sizing: border-box;
  padding: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 30rpx;
  background: rgba(255, 253, 249, 0.88);
  box-shadow: 0 14rpx 32rpx rgba(91, 60, 39, 0.1), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.dish-card.is-sold-out {
  background: rgba(245, 239, 232, 0.78);
}

.dish-image-window {
  position: relative;
  width: 176rpx;
  height: 176rpx;
  flex: none;
  overflow: hidden;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 28% 18%, rgba(255, 227, 180, 0.7), transparent 42%),
    linear-gradient(135deg, rgba(255, 250, 242, 0.96), rgba(247, 221, 202, 0.9));
  box-shadow: 0 12rpx 24rpx rgba(107, 74, 61, 0.12);
}

.dish-card.is-sold-out .dish-image-source {
  opacity: 0.58;
}

.dish-image-source {
  position: absolute;
  width: 100%;
  height: 100%;
  max-width: none;
}

.dish-image-source.is-placeholder {
  box-sizing: border-box;
  padding: 32rpx;
}

.dish-image-gloss {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 24rpx;
  box-shadow: inset 0 -18rpx 34rpx rgba(61, 37, 23, 0.04);
}

.sold-out-badge {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 7rpx 13rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 999rpx;
  background: rgba(64, 48, 39, 0.78);
  color: #fff1dc;
  font-size: 18rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 18rpx rgba(29, 19, 14, 0.24);
}

.dish-info {
  min-width: 0;
  flex: 1;
  padding: 4rpx 2rpx 2rpx 22rpx;
}

.dish-name {
  color: #281d17;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.25;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 9rpx;
  margin-top: 10rpx;
}

.dish-tag {
  padding: 5rpx 10rpx;
  border: 1rpx solid rgba(239, 62, 68, 0.12);
  border-radius: 999rpx;
  background: rgba(255, 242, 238, 0.92);
  color: #d94335;
  font-size: 17rpx;
  font-weight: 700;
}

.dish-tag.sold-out-tag {
  border-color: rgba(216, 121, 24, 0.16);
  background: #fff3df;
  color: #d87918;
  font-weight: bold;
}

.dish-description {
  height: 52rpx;
  margin-top: 9rpx;
  overflow: hidden;
  color: #75655b;
  font-size: 21rpx;
  line-height: 1.5;
}

.dish-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 8rpx;
}

.dish-price {
  color: #ef333b;
  font-size: 32rpx;
  font-weight: 900;
}

.add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.52);
  border-radius: 50%;
  background: linear-gradient(145deg, #ff5b4d, #ef333b);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 22rpx rgba(239, 51, 59, 0.3), inset 0 2rpx 2rpx rgba(255, 255, 255, 0.35);
}

.add-button.is-options {
  width: 124rpx;
  height: 58rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.add-button.is-disabled {
  width: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #d8cec4, #a99a8e);
  color: rgba(255, 255, 255, 0.86);
  font-size: 22rpx;
  box-shadow: none;
}

.empty-dishes {
  padding: 80rpx 20rpx;
  color: #8a796e;
  text-align: center;
}

.empty-emblem {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  margin: 0 auto 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 50%;
  background: rgba(255, 252, 247, 0.78);
  color: #d7b579;
  box-shadow: 0 12rpx 24rpx rgba(91, 60, 39, 0.08);
}

.empty-title {
  color: #5f5047;
  font-size: 24rpx;
}

.empty-desc {
  margin-top: 7rpx;
  font-size: 19rpx;
}

.empty-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  height: 62rpx;
  margin: 26rpx auto 0;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff5b4d, #ef333b);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
  line-height: 62rpx;
  box-shadow: 0 10rpx 22rpx rgba(239, 51, 59, 0.24), inset 0 2rpx 2rpx rgba(255, 255, 255, 0.3);
}

.empty-action::after {
  border: 0;
}

.list-spacer {
  height: calc(390rpx + env(safe-area-inset-bottom));
}

.cart-bar {
  position: fixed;
  z-index: 30;
  right: 32rpx;
  bottom: calc(126rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  display: flex;
  align-items: center;
  height: 102rpx;
  box-sizing: border-box;
  padding: 10rpx 12rpx 10rpx 16rpx;
  border-radius: 42rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  background: rgba(255, 250, 244, 0.9);
  box-shadow: 0 16rpx 34rpx rgba(91, 60, 39, 0.16), inset 0 2rpx 0 rgba(255, 255, 255, 0.92);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.cart-icon-wrap {
  position: relative;
  flex: none;
}

.cart-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border: 0;
  border-radius: 50%;
  background: transparent;
  box-shadow: none;
}

.cart-count {
  position: absolute;
  top: -10rpx;
  right: -5rpx;
  min-width: 30rpx;
  height: 30rpx;
  box-sizing: border-box;
  padding: 0 7rpx;
  border: 2rpx solid #fff1e2;
  border-radius: 999rpx;
  background: #ef333b;
  color: #ffffff;
  font-size: 17rpx;
  font-weight: bold;
  line-height: 26rpx;
  text-align: center;
}

.cart-summary {
  min-width: 118rpx;
  margin-left: 18rpx;
}

.cart-price {
  color: #2a211d;
  font-size: 28rpx;
  font-weight: 900;
}

.cart-tip {
  margin-top: 2rpx;
  color: #8c7b70;
  font-size: 17rpx;
}

.cart-saving {
  min-width: 0;
  flex: 1;
  padding-left: 17rpx;
  border-left: 1rpx solid rgba(151, 119, 94, 0.16);
  color: #8c7b70;
  font-size: 17rpx;
}

.cart-saving text {
  color: #ef333b;
  font-size: 21rpx;
  font-weight: bold;
}

.checkout-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 168rpx;
  height: 72rpx;
  flex: none;
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff5b4d, #ef333b);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: bold;
  box-shadow: 0 12rpx 24rpx rgba(239, 51, 59, 0.28), inset 0 2rpx 2rpx rgba(255, 255, 255, 0.35);
}

.menu-tabbar {
  position: fixed;
  z-index: 25;
  right: 30rpx;
  bottom: calc(12rpx + env(safe-area-inset-bottom));
  left: 30rpx;
  display: flex;
  height: 94rpx;
  border-radius: 30rpx;
  border-color: rgba(255, 255, 255, 0.82);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.88), rgba(255, 248, 238, 0.68));
  box-shadow:
    0 16rpx 38rpx rgba(126, 90, 45, 0.13),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.92);
  -webkit-backdrop-filter: blur(24px) saturate(150%);
  backdrop-filter: blur(24px) saturate(150%);
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  color: #7f6e63;
  font-size: 18rpx;
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 34rpx;
  margin-bottom: 3rpx;
  border: 2rpx solid currentColor;
  border-radius: 12rpx;
  font-size: 15rpx;
  font-weight: bold;
}

.tab-item.is-active {
  color: #ef333b;
  font-weight: bold;
}

.tab-item.is-active .tab-icon {
  border-color: #ec343b;
  background: #d6232c;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(214, 35, 44, 0.32);
}

.shop-name,
.member-title,
.promo-title,
.dish-section-title,
.dish-name,
.dish-description,
.empty-title,
.empty-desc,
.fallback-title,
.fallback-desc {
  overflow-wrap: anywhere;
}

.shop-name,
.dish-name,
.dish-description,
.fallback-desc {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.shop-name,
.dish-name {
  -webkit-line-clamp: 2;
}

.dish-description,
.fallback-desc {
  -webkit-line-clamp: 2;
}

.empty-dishes {
  box-sizing: border-box;
  margin: 8rpx 2rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 30rpx;
  background: rgba(255, 251, 246, 0.72);
  box-shadow: 0 14rpx 30rpx rgba(91, 60, 39, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}

.empty-emblem {
  font-weight: bold;
  box-shadow: inset 0 0 0 1rpx rgba(230, 59, 74, 0.08);
}

.empty-action,
.fallback-retry,
.checkout-button {
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.sold-out-badge,
.dish-tag.sold-out-tag {
  border-radius: 999rpx;
  font-weight: bold;
}

.nav-icon-image,
.search-icon-image,
.empty-icon-image,
.cart-icon-image,
.tab-icon-image {
  display: block;
}

.nav-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.search-icon-image {
  width: 28rpx;
  height: 28rpx;
}

.empty-icon-image {
  width: 54rpx;
  height: 54rpx;
}

.cart-icon-image {
  width: 68rpx;
  height: 68rpx;
}

.tab-icon {
  width: 48rpx;
  height: 46rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.tab-icon-image {
  width: 46rpx;
  height: 46rpx;
}

.tab-item.is-active .tab-icon {
  border-color: transparent;
  background: transparent;
  color: #d82e36;
  box-shadow: none;
}
