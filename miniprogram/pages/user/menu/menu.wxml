<view class="menu-page">
  <view class="menu-background">
    <view class="background-food-window">
      <image
        wx:if="{{homeImageAvailable}}"
        class="background-food"
        src="{{homeReference}}"
        mode="widthFix"
        binderror="handleHomeImageError"
      ></image>
    </view>
    <view class="background-shade"></view>
  </view>

  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navigationHeight}}px;">
    <view class="back-button" bindtap="goBack"><image class="nav-icon-image" src="/images/icons/icon-back.svg" mode="aspectFit"></image></view>
    <view class="nav-title">点餐</view>
    <view class="nav-placeholder"></view>
  </view>

  <view class="menu-header">
    <view class="shop-panel dark-glass">
      <view class="shop-copy">
        <view class="shop-name">{{merchant.name}}</view>
        <view class="shop-branch">{{merchant.branch}}</view>
        <view class="shop-status"><text></text>{{merchant.statusText}}</view>
        <view class="shop-notice">{{merchant.notice}}</view>
      </view>
      <view class="shop-photo">
        <image
          wx:if="{{homeImageAvailable}}"
          class="shop-photo-source"
          src="{{homeReference}}"
          mode="widthFix"
          binderror="handleHomeImageError"
        ></image>
      </view>
      <view class="search-button" bindtap="openSearch"><image class="search-icon-image" src="/images/icons/icon-search.svg" mode="aspectFit"></image></view>
    </view>
  </view>

  <view wx:if="{{usingFallback}}" class="fallback-notice dark-glass">
    <view class="fallback-copy">
      <view class="fallback-title">{{fallbackNoticeTitle}}</view>
      <view class="fallback-desc">{{fallbackNoticeDesc}}</view>
    </view>
    <view class="fallback-retry" bindtap="retryLoad">重试</view>
  </view>

  <view class="menu-body dark-glass">
    <scroll-view class="category-list" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{activeCategory === item.id ? 'is-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectCategory"
      >
        <text class="category-mark"></text>
        <view class="category-label">{{item.name}}</view>
        <view wx:if="{{item.badge}}" class="category-badge">{{item.badge}}</view>
      </view>
    </scroll-view>

    <scroll-view class="dish-list" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="dish-section-head">
        <view>
          <view class="dish-section-title">本店推荐</view>
          <view class="dish-section-subtitle">精心为你挑选</view>
        </view>
        <view class="dish-section-count">{{dishes.length}} 款 ›</view>
      </view>

      <view wx:if="{{pageStatus === 'loading'}}" class="empty-dishes">
        <view class="empty-emblem"><image class="empty-icon-image" src="/images/icons/icon-empty-dish.svg" mode="aspectFit"></image></view>
        <view class="empty-title">菜单加载中</view>
        <view class="empty-desc">正在读取门店餐品</view>
      </view>

      <view wx:elif="{{pageStatus === 'error'}}" class="empty-dishes">
        <view class="empty-emblem"><image class="empty-icon-image" src="/images/icons/icon-warning.svg" mode="aspectFit"></image></view>
        <view class="empty-title">{{emptyTitle}}</view>
        <view class="empty-desc">{{emptyDesc}}</view>
        <button class="empty-action" bindtap="retryLoad">重新加载</button>
      </view>

      <view wx:elif="{{dishes.length}}" class="dish-items">
        <view
          wx:for="{{dishes}}"
          wx:key="_id"
          class="dish-card {{item.is_sold_out ? 'is-sold-out' : ''}}"
          data-id="{{item._id}}"
          bindtap="openDish"
        >
          <view class="dish-image-window">
            <image
              class="dish-image-source {{item.is_placeholder_image ? 'is-placeholder' : ''}}"
              src="{{item.display_image}}"
              style="{{item.image_style}}"
              mode="{{item.image_mode}}"
              lazy-load="{{true}}"
              data-id="{{item._id}}"
              binderror="handleDishImageError"
            ></image>
            <view class="dish-image-gloss"></view>
            <view wx:if="{{item.is_sold_out}}" class="sold-out-badge">已售罄</view>
          </view>
          <view class="dish-info">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-tags">
              <view wx:if="{{item.is_sold_out}}" class="dish-tag sold-out-tag">已售罄</view>
              <view wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="dish-tag">{{tag}}</view>
            </view>
            <view class="dish-description">{{item.description}}</view>
            <view class="dish-footer">
              <view class="dish-price">{{item.price_text}}</view>
              <view class="add-button {{item.has_options ? 'is-options' : ''}} {{item.is_sold_out ? 'is-disabled' : ''}}" data-id="{{item._id}}" catchtap="addDish">{{item.is_sold_out ? '售罄' : (item.has_options ? '选规格' : '＋')}}</view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="empty-dishes">
        <view class="empty-emblem"><image class="empty-icon-image" src="/images/icons/icon-empty-dish.svg" mode="aspectFit"></image></view>
        <view class="empty-title">{{emptyTitle}}</view>
        <view class="empty-desc">{{emptyDesc}}</view>
      </view>
      <view class="list-spacer"></view>
    </scroll-view>
  </view>

  <view class="cart-bar dark-glass" bindtap="goToCart">
    <view class="cart-icon-wrap">
      <view class="cart-icon"><image class="cart-icon-image" src="/images/ui-icons/cart.png" mode="aspectFit"></image></view>
      <view class="cart-count">{{cartCount}}</view>
    </view>
    <view class="cart-summary">
      <view class="cart-price">{{cartAmountText}}</view>
      <view class="cart-tip">已选 {{cartCount}} 件</view>
    </view>
    <view class="cart-saving">预计优惠 <text>¥6.00</text></view>
    <view class="checkout-button">去结算</view>
  </view>

  <view class="menu-tabbar dark-glass">
    <view class="tab-item" bindtap="goHome"><view class="tab-icon"><image class="tab-icon-image" src="/images/ui-icons/tab-home.png" mode="aspectFit"></image></view><view>首页</view></view>
    <view class="tab-item is-active"><view class="tab-icon"><image class="tab-icon-image" src="/images/ui-icons/tab-menu.png" mode="aspectFit"></image></view><view>点餐</view></view>
    <view class="tab-item" bindtap="goToOrders"><view class="tab-icon"><image class="tab-icon-image" src="/images/ui-icons/tab-order.png" mode="aspectFit"></image></view><view>订单</view></view>
  </view>
</view>
