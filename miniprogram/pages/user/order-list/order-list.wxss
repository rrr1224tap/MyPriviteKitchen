page {
  min-height: 100%;
  background: #f7efe6;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.order-list-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #2f241e;
  background:
    radial-gradient(circle at 16% 0%, rgba(255, 255, 255, 0.9), transparent 30%),
    radial-gradient(circle at 84% 8%, rgba(255, 202, 128, 0.22), transparent 30%),
    linear-gradient(180deg, #fbf4ec 0%, #f6eadf 52%, #f9f2eb 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 58vh;
  opacity: 0.1;
  filter: blur(10rpx);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 250, 245, 0.54) 0%, rgba(247, 239, 230, 0.86) 46%, rgba(249, 242, 235, 0.98) 100%),
    radial-gradient(circle at 50% 42%, rgba(255, 229, 188, 0.24), transparent 42%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 50%;
  color: #2f241e;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  text-align: center;
  pointer-events: auto;
  background: rgba(255, 250, 245, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: 0 10rpx 26rpx rgba(75, 49, 30, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #2f241e;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.order-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.order-content {
  padding: 0 28rpx calc(52rpx + env(safe-area-inset-bottom));
}

.glass-panel {
  background: rgba(255, 250, 245, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.74);
  box-shadow: 0 18rpx 44rpx rgba(88, 57, 33, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18px);
}

.order-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255, 250, 245, 0.9);
}

.hero-kicker {
  color: #b38145;
  font-size: 20rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 8rpx;
  color: #2b201a;
  font-size: 42rpx;
  font-weight: 800;
}

.hero-desc {
  margin-top: 8rpx;
  color: #7b6759;
  font-size: 23rpx;
}

.refresh-note {
  display: inline-flex;
  max-width: 100%;
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #8f7768;
  font-size: 21rpx;
  line-height: 1.25;
  background: rgba(255, 246, 236, 0.74);
  overflow-wrap: anywhere;
}

.refresh-note.is-error {
  color: #b93a2f;
  background: rgba(255, 238, 232, 0.82);
}

.hero-action,
.state-button {
  flex-shrink: 0;
  min-width: 156rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  background: linear-gradient(145deg, #ff5448, #ec2423);
  box-shadow: 0 12rpx 28rpx rgba(219, 38, 32, 0.26);
}

.state-card {
  margin-top: 28rpx;
  padding: 88rpx 40rpx;
  border-radius: 34rpx;
  text-align: center;
  background: rgba(255, 249, 240, 0.78);
  color: #2c211d;
}

.state-mark {
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 50%;
  color: #e63b4a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: inset 0 0 0 1rpx rgba(230, 59, 74, 0.12);
}

.state-title {
  color: #2a211d;
  font-size: 32rpx;
  font-weight: 800;
}

.state-desc {
  margin: 14rpx auto 0;
  max-width: 480rpx;
  color: rgba(42, 33, 29, 0.58);
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  display: inline-block;
  margin-top: 28rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 28rpx;
}

.order-card {
  padding: 26rpx;
  border-radius: 30rpx;
  background: rgba(255, 250, 244, 0.84);
  color: #2a211d;
  box-shadow: 0 18rpx 38rpx rgba(68, 36, 23, 0.12);
}

.order-card-head,
.order-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.order-card-main {
  min-width: 0;
  flex: 1;
}

.order-no {
  display: -webkit-box;
  overflow: hidden;
  color: #2a211d;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow-wrap: anywhere;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.order-time {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.5);
  font-size: 22rpx;
}

.status-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status-pending {
  color: #d87918;
  background: #fff1dd;
}

.status-accepted {
  color: #e63b4a;
  background: #fff0f2;
}

.status-cooking {
  color: #df6b23;
  background: #fff1dd;
}

.status-finished {
  color: #4b8e33;
  background: #e8f6e8;
}

.status-cancelled {
  color: #8f6f5a;
  background: #f1e8df;
}

.status-unknown {
  color: #8a6b42;
  background: #fff5df;
}

.order-summary {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  color: rgba(42, 33, 29, 0.72);
  font-size: 24rpx;
  line-height: 1.45;
  background: rgba(255, 246, 236, 0.72);
  overflow-wrap: anywhere;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.order-card-foot {
  margin-top: 22rpx;
}

.order-card-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 22rpx;
}

.cancel-order-button {
  box-sizing: border-box;
  min-width: 160rpx;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #b93a2f;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
  background: rgba(255, 238, 232, 0.92);
  box-shadow: inset 0 0 0 1rpx rgba(185, 58, 47, 0.18);
}

.cancel-order-button.is-loading,
.cancel-order-button[disabled] {
  color: rgba(117, 78, 65, 0.58);
  background: rgba(244, 232, 222, 0.82);
  box-shadow: inset 0 0 0 1rpx rgba(117, 78, 65, 0.1);
}

.order-count {
  min-width: 0;
  flex: 1;
  color: rgba(42, 33, 29, 0.5);
  font-size: 23rpx;
}

.order-total {
  flex: none;
  color: #f2312c;
  font-size: 34rpx;
  font-weight: 900;
}

.order-hero > view:first-child,
.order-card-main {
  min-width: 0;
}

.hero-title,
.hero-desc,
.refresh-note,
.state-title,
.state-desc,
.order-time,
.order-count,
.order-total {
  overflow-wrap: anywhere;
}

.hero-desc,
.refresh-note,
.order-time,
.order-count {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.hero-desc {
  -webkit-line-clamp: 2;
}

.refresh-note {
  -webkit-line-clamp: 1;
}

.order-time,
.order-count {
  -webkit-line-clamp: 1;
}

.hero-action,
.state-button,
.status-tag {
  box-sizing: border-box;
}

.status-tag {
  min-height: 46rpx;
  line-height: 1.2;
  text-align: center;
}
