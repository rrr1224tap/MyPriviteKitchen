page {
  min-height: 100%;
  background: #f7efe6;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.order-detail-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #2f241e;
  background:
    radial-gradient(circle at 15% 0%, rgba(255, 255, 255, 0.9), transparent 30%),
    radial-gradient(circle at 84% 8%, rgba(255, 202, 128, 0.22), transparent 30%),
    linear-gradient(180deg, #fbf4ec 0%, #f6eadf 52%, #f9f2eb 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 58vh;
  opacity: 0.1;
  filter: blur(10rpx);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 250, 245, 0.54) 0%, rgba(247, 239, 230, 0.86) 46%, rgba(249, 242, 235, 0.98) 100%),
    radial-gradient(circle at 50% 40%, rgba(255, 229, 188, 0.24), transparent 42%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 50%;
  background: rgba(255, 250, 245, 0.78);
  color: #2f241e;
  font-family: serif;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  pointer-events: auto;
  box-shadow: 0 10rpx 26rpx rgba(75, 49, 30, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #2f241e;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.detail-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.detail-content {
  padding: 0 28rpx calc(52rpx + env(safe-area-inset-bottom));
}

.glass-panel {
  border: 1rpx solid rgba(255, 255, 255, 0.74);
  background: rgba(255, 250, 245, 0.88);
  box-shadow: 0 18rpx 44rpx rgba(88, 57, 33, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18px);
}

.warm-glass {
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  background: rgba(255, 250, 245, 0.9);
  color: #2b201a;
  box-shadow: 0 16rpx 38rpx rgba(61, 39, 25, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18px);
}

.detail-hero,
.progress-panel,
.items-panel,
.info-panel,
.total-panel,
.state-card {
  box-sizing: border-box;
  border-radius: 32rpx;
}

.detail-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding: 30rpx;
}

.detail-hero > view:first-child {
  min-width: 0;
  flex: 1;
}

.hero-kicker,
.section-kicker {
  color: #b38145;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.hero-title {
  margin-top: 8rpx;
  color: #2b201a;
  font-size: 44rpx;
  font-weight: 900;
}

.hero-status-desc {
  margin-top: 8rpx;
  color: #7b6759;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.hero-desc {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 10rpx;
  color: #8f7768;
  font-size: 23rpx;
  line-height: 1.35;
  overflow-wrap: anywhere;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.hero-time {
  margin-top: 8rpx;
  color: #a48e7e;
  font-size: 21rpx;
}

.status-tag {
  flex-shrink: 0;
  padding: 11rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status-pending {
  color: #d87918;
  background: #fff1dd;
}

.status-accepted {
  color: #e63b4a;
  background: #fff0f2;
}

.status-cooking {
  color: #df6b23;
  background: #fff1dd;
}

.status-finished {
  color: #4b8e33;
  background: #e8f6e8;
}

.status-cancelled {
  color: #8f6f5a;
  background: #f1e8df;
}

.status-unknown {
  color: #8a6b42;
  background: #fff5df;
}

.progress-panel,
.items-panel,
.info-panel,
.total-panel {
  margin-top: 22rpx;
  padding: 28rpx;
}

.order-action-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 22rpx;
  margin-top: 22rpx;
  padding: 24rpx 28rpx;
}

.order-action-panel > view:first-child {
  min-width: 0;
  flex: 1;
}

.action-title {
  color: #2b201a;
  font-size: 27rpx;
  font-weight: 800;
}

.action-desc {
  margin-top: 8rpx;
  color: #8f7768;
  font-size: 22rpx;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.action-desc.is-error {
  color: #b93a2f;
}

.order-action-buttons {
  display: flex;
  flex: none;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 14rpx;
}

.cancel-order-button,
.refresh-status-button {
  box-sizing: border-box;
  min-width: 166rpx;
  height: 60rpx;
  flex: none;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 60rpx;
  text-align: center;
  background: linear-gradient(145deg, #ff5448, #ec2423);
  box-shadow: 0 12rpx 28rpx rgba(219, 38, 32, 0.22);
}

.refresh-status-button {
  color: #7a4b36;
  background: rgba(255, 246, 236, 0.92);
  box-shadow: inset 0 0 0 1rpx rgba(122, 75, 54, 0.16);
}

.cancel-order-button.is-loading,
.cancel-order-button[disabled],
.refresh-status-button.is-loading,
.refresh-status-button[disabled] {
  color: #c7b7aa;
  background: rgba(236, 226, 216, 0.68);
  box-shadow: inset 0 0 0 1rpx rgba(119, 83, 55, 0.08);
}

.section-head,
.total-panel,
.order-item,
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-head > view:first-child {
  min-width: 0;
}

.section-title {
  margin-top: 6rpx;
  color: #2b201a;
  font-size: 30rpx;
  font-weight: 800;
}

.section-kicker.is-dark,
.section-title.is-dark {
  color: #2b201a;
}

.section-kicker.is-dark {
  color: #b17839;
}

.timeline {
  margin-top: 26rpx;
}

.timeline-item {
  position: relative;
  display: flex;
  min-height: 74rpx;
  color: #a48e7e;
}

.timeline-item::before {
  position: absolute;
  top: 24rpx;
  bottom: -12rpx;
  left: 13rpx;
  width: 2rpx;
  background: rgba(119, 83, 55, 0.12);
  content: '';
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-dot {
  width: 26rpx;
  height: 26rpx;
  flex: none;
  margin-top: 2rpx;
  border: 2rpx solid rgba(119, 83, 55, 0.18);
  border-radius: 50%;
  background: rgba(255, 246, 236, 0.82);
}

.timeline-body {
  min-width: 0;
  padding: 0 0 28rpx 22rpx;
}

.timeline-title {
  font-size: 25rpx;
  font-weight: 700;
}

.timeline-time {
  margin-top: 8rpx;
  font-size: 20rpx;
}

.timeline-item.is-done {
  color: #665448;
}

.timeline-item.is-done .timeline-dot {
  border-color: rgba(230, 59, 74, 0.46);
  background: #e63b4a;
  box-shadow: 0 0 0 7rpx rgba(230, 59, 74, 0.12);
}

.timeline-item.is-active .timeline-title {
  color: #2b201a;
}

.item-count {
  padding: 9rpx 15rpx;
  border-radius: 999rpx;
  color: #d7353f;
  font-size: 20rpx;
  font-weight: 700;
  background: rgba(230, 59, 74, 0.1);
}

.order-item {
  align-items: flex-start;
  margin-top: 22rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(82, 53, 35, 0.08);
}

.dish-emblem {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  flex: none;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #ff5448, #ec2423);
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.dish-info {
  min-width: 0;
  flex: 1;
}

.dish-name {
  display: -webkit-box;
  overflow: hidden;
  color: #2a211d;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow-wrap: anywhere;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.dish-options {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 8rpx;
}

.dish-option-line {
  display: -webkit-box;
  overflow: hidden;
  color: rgba(42, 33, 29, 0.58);
  font-size: 20rpx;
  line-height: 1.35;
  overflow-wrap: anywhere;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.dish-price {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.5);
  font-size: 21rpx;
}

.dish-side {
  max-width: 180rpx;
  flex: none;
  text-align: right;
}

.dish-quantity {
  color: rgba(42, 33, 29, 0.48);
  font-size: 22rpx;
}

.dish-subtotal {
  margin-top: 8rpx;
  color: #f2312c;
  font-size: 27rpx;
  font-weight: 900;
  overflow-wrap: anywhere;
}

.items-empty {
  margin-top: 22rpx;
  padding: 28rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 246, 236, 0.72);
  color: rgba(42, 33, 29, 0.58);
  font-size: 24rpx;
  text-align: center;
}

.info-row {
  align-items: flex-start;
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 246, 236, 0.72);
}

.info-label {
  flex: none;
  color: #9b8677;
  font-size: 22rpx;
}

.info-value {
  min-width: 0;
  max-width: 430rpx;
  flex: 1;
  color: #2b201a;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
  text-align: right;
  overflow-wrap: anywhere;
}

.total-panel {
  min-height: 128rpx;
}

.total-label {
  color: #2b201a;
  font-size: 28rpx;
  font-weight: 800;
}

.total-note {
  margin-top: 8rpx;
  color: #9b8677;
  font-size: 19rpx;
}

.total-price {
  flex: none;
  color: #f2312c;
  font-size: 42rpx;
  font-weight: 900;
  overflow-wrap: anywhere;
}

.continue-button,
.state-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 78rpx;
  background: linear-gradient(145deg, #ff5448, #ec2423);
  box-shadow: 0 12rpx 28rpx rgba(219, 38, 32, 0.26);
}

.continue-button {
  margin-top: 28rpx;
}

.state-card {
  margin-top: 120rpx;
  padding: 88rpx 40rpx;
  text-align: center;
  background: rgba(255, 249, 240, 0.78);
  color: #2c211d;
}

.state-mark {
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 50%;
  color: #e63b4a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: inset 0 0 0 1rpx rgba(230, 59, 74, 0.12);
}

.state-title {
  color: #2a211d;
  font-size: 32rpx;
  font-weight: 800;
}

.state-desc {
  margin: 14rpx auto 0;
  max-width: 500rpx;
  color: rgba(42, 33, 29, 0.58);
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  width: 240rpx;
  margin: 30rpx auto 0;
}

.state-actions {
  display: flex;
  justify-content: center;
  gap: 18rpx;
  margin-top: 30rpx;
}

.state-actions .state-button {
  margin: 0;
}

.state-button.is-secondary {
  color: #7c5848;
  background: rgba(255, 246, 236, 0.84);
  box-shadow: inset 0 0 0 1rpx rgba(124, 88, 72, 0.12);
}

.hero-title,
.hero-status-desc,
.hero-time,
.section-title,
.timeline-title,
.timeline-time,
.items-empty,
.state-title,
.state-desc {
  overflow-wrap: anywhere;
}

.status-tag,
.item-count,
.continue-button,
.state-button,
.info-row {
  box-sizing: border-box;
}

.status-tag,
.item-count {
  min-height: 46rpx;
  line-height: 1.2;
  text-align: center;
}

.state-actions {
  flex-wrap: wrap;
}
