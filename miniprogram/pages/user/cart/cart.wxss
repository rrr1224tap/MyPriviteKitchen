.cart-page {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
  background: #f7efe6;
  color: #2f241e;
}

.cart-background,
.background-shade {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
}

.background-image-window {
  position: absolute;
  top: -130rpx;
  right: -230rpx;
  width: 840rpx;
  height: 900rpx;
  overflow: hidden;
  opacity: 0.14;
  filter: blur(18rpx);
}

.background-image {
  position: absolute;
  top: -100rpx;
  left: -260rpx;
  width: 980rpx;
  max-width: none;
}

.background-shade {
  background:
    radial-gradient(circle at 78% 10%, rgba(255, 205, 157, 0.28), transparent 430rpx),
    radial-gradient(circle at 12% 4%, rgba(255, 255, 255, 0.92), transparent 270rpx),
    linear-gradient(180deg, #fbf4ec 0%, #f6eadf 52%, #f9f2eb 100%);
}

.glass-panel {
  border: 1rpx solid rgba(255, 255, 255, 0.74);
  background: rgba(255, 250, 245, 0.88);
  box-shadow: 0 18rpx 44rpx rgba(88, 57, 33, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.warm-glass {
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  background: rgba(255, 250, 245, 0.9);
  color: #2b201a;
  box-shadow: 0 16rpx 38rpx rgba(61, 39, 25, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.custom-nav {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: content-box;
  padding-right: 30rpx;
  padding-left: 30rpx;
}

.back-button,
.clear-button,
.nav-placeholder {
  width: 64rpx;
  height: 62rpx;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 50%;
  background: rgba(255, 250, 245, 0.78);
  color: #2f241e;
  font-family: serif;
  font-size: 50rpx;
  line-height: 1;
  box-shadow: 0 10rpx 26rpx rgba(75, 49, 30, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
}

.nav-title {
  color: #2f241e;
  font-family: serif;
  font-size: 31rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.clear-button {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  color: #8f7768;
  font-size: 21rpx;
}

.clear-button.is-disabled {
  opacity: 0.42;
}

.cart-content {
  position: relative;
  z-index: 4;
  padding: 22rpx 24rpx 0;
}

.cart-overview,
.cart-item,
.pickup-panel,
.summary-panel,
.empty-state {
  box-sizing: border-box;
  border-radius: 30rpx;
}

.cart-overview {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 27rpx;
}

.overview-kicker,
.section-kicker {
  color: #d1ad72;
  font-size: 16rpx;
  letter-spacing: 3rpx;
}

.overview-title {
  margin-top: 5rpx;
  color: #2b201a;
  font-size: 34rpx;
  font-weight: bold;
}

.overview-desc {
  margin-top: 7rpx;
  color: #8f7768;
  font-size: 20rpx;
}

.overview-count {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  border-radius: 50%;
  background: linear-gradient(145deg, #ff5448, #ec2423);
  color: #ffffff;
  font-size: 31rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 24rpx rgba(219, 38, 32, 0.26), inset 0 2rpx 2rpx rgba(255, 255, 255, 0.3);
}

.overview-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: none;
}

.overview-clear {
  padding: 8rpx 18rpx;
  border: 1rpx solid rgba(119, 83, 55, 0.12);
  border-radius: 999rpx;
  background: rgba(255, 246, 236, 0.82);
  color: #7b6759;
  font-size: 20rpx;
  line-height: 1;
}

.overview-clear.is-disabled {
  opacity: 0.46;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.cart-item {
  display: flex;
  min-height: 210rpx;
  padding: 16rpx;
}

.cart-image-window {
  position: relative;
  width: 182rpx;
  height: 180rpx;
  flex: none;
  overflow: hidden;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 28% 18%, rgba(255, 227, 180, 0.7), transparent 42%),
    linear-gradient(135deg, rgba(255, 250, 242, 0.96), rgba(247, 221, 202, 0.9));
  box-shadow: 0 10rpx 22rpx rgba(107, 74, 61, 0.1);
}

.cart-image {
  position: absolute;
  width: 100%;
  height: 100%;
  max-width: none;
}

.cart-image.is-placeholder {
  box-sizing: border-box;
  padding: 34rpx;
}

.image-gloss {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 24rpx;
  box-shadow: inset 0 -20rpx 34rpx rgba(80, 46, 23, 0.05);
}

.cart-info {
  min-width: 0;
  flex: 1;
  padding: 6rpx 4rpx 4rpx 20rpx;
}

.cart-item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.cart-name {
  min-width: 0;
  flex: 1;
  color: #2b201a;
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1.35;
}

.cart-remove {
  flex: none;
  padding: 6rpx 12rpx;
  border: 1rpx solid rgba(119, 83, 55, 0.1);
  border-radius: 999rpx;
  background: rgba(255, 246, 236, 0.72);
  color: #947c6b;
  font-size: 18rpx;
  line-height: 1;
}

.cart-remove.is-disabled {
  opacity: 0.46;
}

.cart-spec,
.cart-option-summary {
  margin-top: 8rpx;
  color: #8f7768;
  font-size: 19rpx;
}

.cart-option-summary {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.cart-option-line {
  display: -webkit-box;
  overflow: hidden;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}

.cart-item-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 24rpx;
}

.cart-price {
  color: #f2312c;
  font-size: 29rpx;
  font-weight: bold;
}

.cart-subtotal {
  margin-top: 3rpx;
  color: #a48e7e;
  font-size: 16rpx;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 13rpx;
}

.stepper-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border: 1rpx solid rgba(242, 49, 44, 0.18);
  border-radius: 50%;
  background: linear-gradient(145deg, #ff5448, #ec2423);
  color: #ffffff;
  font-size: 29rpx;
  font-weight: bold;
  box-shadow: 0 7rpx 16rpx rgba(219, 38, 32, 0.24), inset 0 2rpx 2rpx rgba(255, 255, 255, 0.3);
}

.stepper-button.is-minus {
  border-color: rgba(119, 83, 55, 0.12);
  background: rgba(255, 246, 236, 0.86);
  color: #8c7565;
  box-shadow: none;
}

.stepper-button.is-disabled {
  border-color: rgba(119, 83, 55, 0.08);
  background: rgba(236, 226, 216, 0.68);
  color: #c7b7aa;
  box-shadow: none;
}

.stepper-value {
  min-width: 27rpx;
  color: #2b201a;
  font-size: 24rpx;
  font-weight: bold;
  text-align: center;
}

.pickup-panel,
.summary-panel {
  margin-top: 18rpx;
  padding: 26rpx;
}

.section-head,
.summary-head,
.summary-total {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title,
.summary-title {
  margin-top: 5rpx;
  font-size: 29rpx;
  font-weight: bold;
}

.pickup-time {
  padding: 10rpx 15rpx;
  border-radius: 999rpx;
  background: rgba(230, 59, 74, 0.1);
  color: #d7353f;
  font-size: 19rpx;
}

.pickup-options {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.pickup-option {
  position: relative;
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
  min-height: 116rpx;
  box-sizing: border-box;
  padding: 16rpx;
  border: 1rpx solid rgba(119, 83, 55, 0.12);
  border-radius: 24rpx;
  background: rgba(255, 246, 236, 0.64);
}

.pickup-option.is-active {
  border-color: rgba(230, 59, 74, 0.38);
  background: rgba(255, 242, 240, 0.86);
  box-shadow: 0 8rpx 20rpx rgba(204, 49, 60, 0.1);
}

.pickup-option.is-disabled {
  opacity: 0.72;
}

.pickup-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  flex: none;
  margin-right: 12rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #ff5448, #ec2423);
  color: #ffffff;
  font-size: 21rpx;
  font-weight: bold;
}

.pickup-icon.is-dine {
  background: linear-gradient(145deg, #ffb14f, #f07822);
}

.pickup-title {
  color: #2b201a;
  font-size: 23rpx;
  font-weight: bold;
}

.pickup-desc {
  margin-top: 5rpx;
  color: #917b6d;
  font-size: 17rpx;
}

.option-mark {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #c5b5a8;
  border-radius: 50%;
}

.pickup-option.is-active .option-mark {
  border-color: #e63b4a;
  background: #e63b4a;
  box-shadow: 0 0 0 4rpx rgba(230, 59, 74, 0.12);
}

.section-kicker.is-light {
  color: #b38145;
}

.member-pill {
  padding: 10rpx 16rpx;
  border: 1rpx solid rgba(255, 119, 38, 0.18);
  border-radius: 999rpx;
  background: rgba(255, 119, 38, 0.1);
  color: #df6b23;
  font-size: 19rpx;
}

.summary-title {
  color: #2b201a;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  color: #7b6759;
  font-size: 22rpx;
}

.summary-row.is-discount {
  color: #f2312c;
}

.summary-divider {
  height: 1rpx;
  margin: 24rpx 0;
  background: rgba(119, 83, 55, 0.1);
}

.total-label {
  color: #2b201a;
  font-size: 25rpx;
  font-weight: bold;
}

.total-note {
  margin-top: 6rpx;
  color: #9b8677;
  font-size: 18rpx;
}

.total-price {
  color: #f2312c;
  font-size: 38rpx;
  font-weight: bold;
}

.cart-spacer {
  height: calc(176rpx + env(safe-area-inset-bottom));
}

.empty-state {
  position: relative;
  z-index: 4;
  margin: 180rpx 36rpx 0;
  padding: 58rpx 36rpx;
  text-align: center;
}

.empty-emblem {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto;
  border: 1rpx solid rgba(242, 49, 44, 0.12);
  border-radius: 34rpx;
  background: rgba(255, 246, 236, 0.86);
  color: #f2312c;
  font-family: serif;
  font-size: 32rpx;
  font-weight: bold;
  transform: rotate(45deg);
}

.empty-emblem text {
  display: block;
  transform: rotate(-45deg);
}

.empty-title {
  margin-top: 42rpx;
  color: #2b201a;
  font-size: 31rpx;
  font-weight: bold;
}

.empty-desc {
  margin-top: 10rpx;
  color: #8f7768;
  font-size: 21rpx;
}

.empty-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 270rpx;
  height: 78rpx;
  margin: 32rpx auto 0;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff5448, #ec2423);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: bold;
  line-height: 78rpx;
}

.empty-button::after {
  border: 0;
}

.empty-button text {
  margin-left: 12rpx;
  font-size: 32rpx;
}

.submit-bar {
  position: fixed;
  z-index: 30;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  display: flex;
  align-items: center;
  min-height: 106rpx;
  box-sizing: border-box;
  padding: 12rpx 12rpx 12rpx 22rpx;
  border-radius: 48rpx;
  background: rgba(255, 250, 245, 0.94);
  border-color: rgba(255, 255, 255, 0.82);
}

.submit-summary {
  min-width: 145rpx;
}

.submit-label {
  color: #9b8677;
  font-size: 18rpx;
}

.submit-price {
  margin-top: 2rpx;
  color: #f2312c;
  font-size: 31rpx;
  font-weight: bold;
}

.submit-saving {
  min-width: 0;
  flex: 1;
  padding-left: 16rpx;
  border-left: 1rpx solid rgba(119, 83, 55, 0.1);
  color: #9b8677;
  font-size: 17rpx;
}

.submit-saving text {
  color: #f2312c;
  font-weight: bold;
}

.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 278rpx;
  height: 80rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff5448, #ec2423);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 80rpx;
  box-shadow: 0 12rpx 28rpx rgba(219, 38, 32, 0.28), inset 0 2rpx 2rpx rgba(255, 255, 255, 0.34);
}

.submit-button.is-disabled {
  border-color: rgba(119, 83, 55, 0.08);
  background: linear-gradient(145deg, #e3d7cd, #c5b4a7);
  color: rgba(255, 255, 255, 0.9);
  box-shadow: none;
}

.submit-button::after {
  border: 0;
}

.submit-button text {
  margin-left: 12rpx;
  font-size: 34rpx;
  font-weight: normal;
}

.overview-title,
.overview-desc,
.cart-name,
.cart-option-line,
.pickup-title,
.pickup-desc,
.summary-row,
.total-note,
.empty-title,
.empty-desc,
.submit-saving {
  overflow-wrap: anywhere;
}

.cart-name {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.cart-option-line {
  -webkit-line-clamp: 2;
}

.overview-clear,
.cart-remove,
.empty-button,
.submit-button,
.stepper-button,
.pickup-option {
  box-sizing: border-box;
}

.empty-state {
  border: 1rpx solid rgba(255, 255, 255, 0.74);
}

.nav-icon-image,
.pickup-icon-image,
.empty-icon-image {
  display: block;
}

.nav-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.pickup-icon-image {
  width: 32rpx;
  height: 32rpx;
}

.empty-icon-image {
  width: 62rpx;
  height: 62rpx;
  transform: rotate(-45deg);
}
