<view class="launch-page">
  <view class="hero-section">
    <view class="hero-ambient hero-ambient-one"></view>
    <view class="hero-ambient hero-ambient-two"></view>
    <view class="hero-food-window">
      <image
        wx:if="{{homeImageAvailable}}"
        class="hero-food-image"
        src="{{homeReference}}"
        mode="widthFix"
        binderror="handleHomeImageError"
      ></image>
      <image
        wx:else
        class="hero-food-placeholder"
        src="/images/placeholders/food-placeholder.svg"
        mode="aspectFit"
      ></image>
    </view>
    <view class="hero-vignette"></view>

    <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navigationHeight}}px;">
      <view class="nav-wordmark">朋友们的食堂</view>
    </view>

    <view class="hero-copy">
      <view class="brand-sign">
        <view class="brand-cn">朋友们的食堂</view>
        <view class="brand-en">FRIENDS' CANTEEN</view>
      </view>
      <view class="hero-desc">现炒现做 · <text>锅气十足</text> · 每一碗都很用心</view>
      <view class="hero-status-row">
        <view class="hero-status-pill hero-status-open"><text class="status-dot"></text>营业中</view>
        <view class="hero-status-pill">
          <image class="status-icon" src="/images/icons/icon-clock.svg" mode="aspectFit"></image>
          <text>10:30-21:30</text>
        </view>
      </view>
      <button class="hero-button" bindtap="goToMenu">
        <text>今天吃啥</text>
      </button>
    </view>
  </view>

  <view class="home-content">
    <view class="entry-row">
      <view class="entry-card dine-card glass-light" bindtap="goToMenu">
        <view class="entry-icon dine-icon">
          <image class="ui-icon entry-icon-image" src="/images/ui-icons/home-eat.png" mode="aspectFit"></image>
        </view>
        <view class="entry-title">回家吃饭</view>
        <view class="entry-desc">我今天必须吃到</view>
      </view>
      <view class="entry-card pickup-card glass-light" bindtap="goToMenu">
        <view class="entry-icon pickup-icon">
          <image class="ui-icon entry-icon-image" src="/images/ui-icons/work-lunch.png" mode="aspectFit"></image>
        </view>
        <view class="entry-title">上班带饭</view>
        <view class="entry-desc">明天上班吃点啥</view>
      </view>
      <view class="entry-card order-card-entry glass-light" bindtap="goToOrders">
        <view class="entry-icon order-entry-icon">
          <image class="ui-icon entry-icon-image" src="/images/ui-icons/my-meal.png" mode="aspectFit"></image>
        </view>
        <view class="entry-title">我的饭呢！</view>
        <view class="entry-desc">咋还没做好</view>
      </view>
    </view>

    <view class="recommend-section">
      <view class="recommend-head">
        <view>
          <view class="recommend-title">
            <image class="recommend-title-icon" src="/images/ui-icons/wok-cook.png" mode="aspectFit"></image>
            <text>今日推荐</text>
          </view>
          <view class="recommend-subtitle">厨师今天想吃</view>
        </view>
        <view class="recommend-more" bindtap="goToMenu">查看更多</view>
      </view>

      <view class="recommend-row">
        <view class="recommend-card glass-light" bindtap="goToMenu">
          <view class="recommend-image-wrap">
            <image wx:if="{{homeImageAvailable}}" class="recommend-image recommend-image-one" src="{{homeReference}}" mode="widthFix"></image>
            <image wx:else class="recommend-image-placeholder" src="/images/placeholders/food-placeholder.svg" mode="aspectFit"></image>
            <view class="recommend-badge recommend-badge-red">招牌</view>
          </view>
          <view class="recommend-name">招牌肥牛石锅拌饭</view>
          <view class="recommend-desc">肥牛鲜嫩 · 锅气十足</view>
          <view class="recommend-bottom">
            <text class="recommend-price">¥29.90</text>
            <view class="recommend-add">+</view>
          </view>
        </view>

        <view class="recommend-card glass-light" bindtap="goToMenu">
          <view class="recommend-image-wrap">
            <image wx:if="{{homeImageAvailable}}" class="recommend-image recommend-image-two" src="{{homeReference}}" mode="widthFix"></image>
            <image wx:else class="recommend-image-placeholder" src="/images/placeholders/food-placeholder.svg" mode="aspectFit"></image>
            <view class="recommend-badge recommend-badge-orange">人气</view>
          </view>
          <view class="recommend-name">黑椒牛肉饭</view>
          <view class="recommend-desc">黑椒浓郁 · 香气扑鼻</view>
          <view class="recommend-bottom">
            <text class="recommend-price">¥26.90</text>
            <view class="recommend-add">+</view>
          </view>
        </view>

        <view class="recommend-card glass-light" bindtap="goToMenu">
          <view class="recommend-image-wrap">
            <image wx:if="{{homeImageAvailable}}" class="recommend-image recommend-image-three" src="{{homeReference}}" mode="widthFix"></image>
            <image wx:else class="recommend-image-placeholder" src="/images/placeholders/food-placeholder.svg" mode="aspectFit"></image>
            <view class="recommend-badge recommend-badge-green">新品</view>
          </view>
          <view class="recommend-name">宫保鸡丁饭</view>
          <view class="recommend-desc">酸甜微辣 · 下饭必点</view>
          <view class="recommend-bottom">
            <text class="recommend-price">¥24.90</text>
            <view class="recommend-add">+</view>
          </view>
        </view>
      </view>

      <view class="recommend-dots">
        <view class="recommend-dot is-active"></view>
        <view class="recommend-dot"></view>
        <view class="recommend-dot"></view>
      </view>
    </view>

    <view class="service-strip glass-light">
      <view class="service-item">
        <image class="service-icon-image service-icon-fresh" src="/images/ui-icons/fresh-food.png" mode="aspectFit"></image>
        <view>
          <view class="service-title">食材新鲜</view>
          <view class="service-desc">每日新鲜配送</view>
        </view>
      </view>
      <view class="service-divider"></view>
      <view class="service-item">
        <image class="service-icon-image service-icon-cook" src="/images/ui-icons/wok-cook.png" mode="aspectFit"></image>
        <view>
          <view class="service-title">现炒现做</view>
          <view class="service-desc">锅气十足</view>
        </view>
      </view>
    </view>

    <view wx:if="{{showMerchantEntry}}" class="merchant-entry glass-light" bindtap="goToMerchant">
      <view class="merchant-entry-icon">
        <image class="merchant-entry-icon-image" src="/images/icons/icon-merchant-orders.svg" mode="aspectFit"></image>
      </view>
      <view class="merchant-entry-copy">
        <view class="merchant-entry-title">朋友们的食堂工作台</view>
        <view class="merchant-entry-desc">照看点菜单与今日菜品</view>
      </view>
    </view>
  </view>

  <view class="premium-tabbar glass-light">
    <view class="tab-item is-active">
      <view class="tab-icon">
        <image class="tab-icon-image" src="/images/ui-icons/tab-home.png" mode="aspectFit"></image>
      </view>
      <view>今天吃啥</view>
    </view>
    <view class="tab-item" bindtap="goToMenu">
      <view class="tab-icon">
        <image class="tab-icon-image" src="/images/ui-icons/tab-menu.png" mode="aspectFit"></image>
      </view>
      <view>今日菜单</view>
    </view>
    <view class="tab-item" bindtap="goToOrders">
      <view class="tab-icon">
        <image class="tab-icon-image" src="/images/ui-icons/tab-order.png" mode="aspectFit"></image>
      </view>
      <view>点菜单</view>
    </view>
  </view>
</view>
