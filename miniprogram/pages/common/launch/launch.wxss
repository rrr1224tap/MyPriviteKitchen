.launch-page {
  min-height: 100vh;
  padding-bottom: calc(192rpx + env(safe-area-inset-bottom));
  overflow: hidden;
  background:
    radial-gradient(circle at 18% 0%, rgba(255, 255, 255, 0.92), transparent 260rpx),
    radial-gradient(circle at 84% 4%, rgba(255, 217, 170, 0.32), transparent 320rpx),
    linear-gradient(180deg, #fbf2e8 0%, #f7efe6 52%, #fbf5ee 100%);
  color: #221814;
}

.hero-section {
  position: relative;
  height: 780rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.9), transparent 260rpx),
    radial-gradient(circle at 76% 26%, rgba(255, 218, 173, 0.36), transparent 360rpx),
    linear-gradient(142deg, #fff8ef 0%, #f7e9d8 54%, #fbf3ea 100%);
}

.hero-ambient {
  position: absolute;
  border-radius: 50%;
  opacity: 0.58;
  filter: blur(50rpx);
}

.hero-ambient-one {
  top: 92rpx;
  right: -34rpx;
  width: 440rpx;
  height: 440rpx;
  background: rgba(255, 206, 145, 0.3);
}

.hero-ambient-two {
  bottom: -92rpx;
  left: -90rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.64);
}

.hero-food-window {
  position: absolute;
  z-index: 1;
  top: 0;
  right: 0;
  left: 0;
  height: 720rpx;
  overflow: hidden;
  border-radius: 0;
}

.hero-food-image {
  position: absolute;
  top: 100rpx;
  right: -146rpx;
  width: 700rpx;
  max-width: none;
  filter: brightness(1.03) saturate(1.04);
}

.hero-food-placeholder {
  position: absolute;
  top: 118rpx;
  right: 132rpx;
  width: 210rpx;
  height: 210rpx;
  opacity: 0.72;
}

.hero-vignette {
  position: absolute;
  z-index: 2;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background:
    linear-gradient(90deg, rgba(255, 249, 241, 0.92) 0%, rgba(255, 249, 241, 0.74) 34%, rgba(255, 249, 241, 0.08) 56%, rgba(255, 249, 241, 0) 100%),
    linear-gradient(0deg, rgba(247, 239, 230, 0.66) 0%, rgba(247, 239, 230, 0) 36%);
}

.custom-nav {
  position: relative;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: content-box;
  color: #241912;
}

.nav-wordmark {
  font-family: "PingFang SC", "Microsoft YaHei", serif;
  font-size: 33rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.hero-copy {
  position: relative;
  z-index: 5;
  width: 452rpx;
  padding: 74rpx 0 0 42rpx;
  color: #251a14;
}

.brand-sign {
  display: inline-flex;
  flex-direction: column;
}

.brand-cn {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  font-family: "PingFang SC", "Microsoft YaHei", serif;
  font-size: 68rpx;
  font-weight: 900;
  line-height: 0.98;
  letter-spacing: 1rpx;
  white-space: nowrap;
}

.brand-en {
  margin-top: 16rpx;
  color: #9a8271;
  font-family: "Times New Roman", serif;
  font-size: 19rpx;
  letter-spacing: 9rpx;
}

.hero-desc {
  margin-top: 28rpx;
  color: #46352c;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
}

.hero-desc text {
  color: #ef2b23;
}

.hero-status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 28rpx;
}

.hero-status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  box-sizing: border-box;
  padding: 0 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  background: rgba(255, 250, 245, 0.76);
  color: #665347;
  font-size: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(93, 62, 36, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
}

.hero-status-open {
  color: #39a83d;
  font-weight: 700;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  margin-right: 9rpx;
  border-radius: 50%;
  background: #42c948;
  box-shadow: 0 0 14rpx rgba(66, 201, 72, 0.42);
}

.status-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.hero-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 278rpx;
  height: 82rpx;
  margin: 42rpx 0 0;
  padding: 0 38rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.48);
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff6640 0%, #f2382a 48%, #e92425 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 82rpx;
  box-shadow: 0 18rpx 36rpx rgba(226, 49, 37, 0.28), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.34);
}

.hero-button::after {
  border: 0;
}

.home-content {
  position: relative;
  z-index: 8;
  margin-top: -30rpx;
  padding: 0 30rpx 52rpx;
  background:
    radial-gradient(circle at 88% 6%, rgba(255, 216, 171, 0.24), transparent 300rpx),
    linear-gradient(180deg, rgba(247, 239, 230, 0) 0%, #f7efe6 220rpx, #fbf5ef 100%);
}

.glass-light {
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(255, 248, 238, 0.62));
  box-shadow:
    0 20rpx 56rpx rgba(126, 90, 45, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95),
    inset 0 -18rpx 42rpx rgba(255, 226, 191, 0.12);
  -webkit-backdrop-filter: blur(22px) saturate(150%);
  backdrop-filter: blur(22px) saturate(150%);
}

.entry-row {
  display: flex;
  gap: 16rpx;
}

.entry-card {
  position: relative;
  min-width: 0;
  height: 252rpx;
  flex: 1;
  box-sizing: border-box;
  padding: 22rpx 20rpx 20rpx;
  overflow: hidden;
  border-radius: 32rpx;
}

.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 98rpx;
  height: 98rpx;
  border-radius: 0;
  background: transparent;
}

.entry-icon-image {
  display: block;
  width: 96rpx;
  height: 96rpx;
}

.dine-icon {
  box-shadow: none;
}

.pickup-icon {
  box-shadow: none;
}

.order-entry-icon {
  box-shadow: none;
}

.entry-title {
  margin-top: 12rpx;
  color: #281d17;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.1;
}

.entry-desc {
  margin-top: 8rpx;
  color: #7f6b5f;
  font-size: 21rpx;
  line-height: 1.25;
  white-space: nowrap;
}

.recommend-section {
  margin-top: 44rpx;
}

.recommend-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin: 0 6rpx 22rpx;
}

.recommend-title {
  display: flex;
  align-items: center;
  color: #231913;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.recommend-title-icon {
  width: 42rpx;
  height: 42rpx;
  margin-right: 7rpx;
}

.recommend-subtitle {
  margin-top: 10rpx;
  color: #7c6759;
  font-size: 23rpx;
}

.recommend-more {
  display: flex;
  align-items: center;
  color: #6d584a;
  font-size: 24rpx;
  line-height: 40rpx;
}

.recommend-row {
  display: flex;
  gap: 16rpx;
}

.recommend-card {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  border-radius: 28rpx;
}

.recommend-image-wrap {
  position: relative;
  height: 178rpx;
  overflow: hidden;
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(255, 244, 232, 0.76);
}

.recommend-image {
  display: block;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: brightness(1.02) saturate(1.04);
}

.recommend-image-placeholder {
  box-sizing: border-box;
  padding: 36rpx;
  opacity: 0.68;
}

.recommend-state {
  padding: 34rpx 28rpx;
  border-radius: 28rpx;
  text-align: center;
}

.recommend-state-title {
  color: #2a1f18;
  font-size: 26rpx;
  font-weight: 800;
}

.recommend-state-desc {
  margin-top: 10rpx;
  color: #806d61;
  font-size: 21rpx;
}

.recommend-badge {
  position: absolute;
  top: 0;
  left: 0;
  min-width: 64rpx;
  height: 42rpx;
  padding: 0 12rpx;
  border-radius: 0 0 18rpx 0;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.recommend-badge-red {
  background: linear-gradient(145deg, #ff5b43, #e92725);
}

.recommend-badge-orange {
  background: linear-gradient(145deg, #ffb13f, #f38318);
}

.recommend-badge-green {
  background: linear-gradient(145deg, #75b65a, #4f9a35);
}

.recommend-name {
  margin: 22rpx 18rpx 0;
  color: #251a14;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.25;
  min-height: 62rpx;
}

.recommend-desc {
  margin: 10rpx 18rpx 0;
  color: #816e62;
  font-size: 21rpx;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recommend-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 22rpx 16rpx 20rpx 18rpx;
}

.recommend-price {
  color: #ee2d27;
  font-size: 27rpx;
  font-weight: 900;
}

.recommend-add {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ff5b43, #ee2d27);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 46rpx;
  box-shadow: 0 8rpx 18rpx rgba(226, 49, 37, 0.24);
}

.recommend-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 24rpx;
}

.recommend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(111, 91, 75, 0.24);
}

.recommend-dot.is-active {
  width: 26rpx;
  background: #e92725;
}

.service-strip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 34rpx;
  padding: 24rpx 18rpx;
  border-radius: 30rpx;
}

.service-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  flex: 1;
}

.service-icon-image {
  display: block;
  width: 72rpx;
  height: 72rpx;
  flex: none;
  margin-right: 16rpx;
}

.service-icon-fresh {
  opacity: 0.92;
}

.service-icon-cook {
  opacity: 0.92;
}

.service-title {
  color: #2a1f18;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.2;
}

.service-desc {
  margin-top: 6rpx;
  color: #806d61;
  font-size: 21rpx;
  line-height: 1.25;
}

.service-divider {
  width: 1rpx;
  height: 64rpx;
  background: rgba(119, 83, 55, 0.14);
}

.merchant-entry {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 30rpx;
  background: rgba(255, 250, 245, 0.84);
}

.merchant-entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  flex: none;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #ffb14f, #f07822);
  box-shadow: 0 10rpx 22rpx rgba(240, 120, 34, 0.18);
}

.merchant-entry-icon-image {
  display: block;
  width: 34rpx;
  height: 34rpx;
}

.merchant-entry-copy {
  min-width: 0;
  flex: 1;
}

.merchant-entry-title {
  color: #2a211d;
  font-size: 25rpx;
  font-weight: 800;
}

.merchant-entry-desc {
  margin-top: 4rpx;
  color: rgba(42, 33, 29, 0.56);
  font-size: 20rpx;
}

.premium-tabbar {
  position: fixed;
  z-index: 30;
  right: 28rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  display: flex;
  height: 116rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(255, 249, 241, 0.72));
  box-shadow:
    0 18rpx 46rpx rgba(126, 90, 45, 0.14),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.92);
  -webkit-backdrop-filter: blur(24px) saturate(150%);
  backdrop-filter: blur(24px) saturate(150%);
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  color: #7b6759;
  font-size: 20rpx;
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 5rpx;
}

.tab-icon-image {
  display: block;
  width: 46rpx;
  height: 46rpx;
}

.tab-item.is-active {
  color: #e63b4a;
  font-weight: 800;
}

.ui-icon {
  display: block;
}
