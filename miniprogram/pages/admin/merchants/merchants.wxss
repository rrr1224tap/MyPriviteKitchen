page {
  min-height: 100%;
  background: #fbf3ea;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.admin-merchants-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #2b211b;
  background:
    radial-gradient(circle at 18% 0%, rgba(255, 255, 255, 0.96), transparent 280rpx),
    radial-gradient(circle at 88% 8%, rgba(255, 205, 142, 0.28), transparent 380rpx),
    linear-gradient(180deg, #fff7ed 0%, #f7efe6 58%, #fbf6ef 100%);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 249, 241, 0.88) 0%, rgba(247, 239, 230, 0.84) 52%, rgba(251, 246, 239, 0.98) 100%),
    radial-gradient(circle at 48% 20%, rgba(255, 216, 166, 0.24), transparent 46%);
}

.custom-nav {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  left: 0;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  bottom: 10rpx;
  left: 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 50%;
  background: rgba(255, 250, 244, 0.72);
  box-shadow: 0 12rpx 28rpx rgba(126, 90, 45, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  pointer-events: auto;
  -webkit-backdrop-filter: blur(18px) saturate(145%);
  backdrop-filter: blur(18px) saturate(145%);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #2b211b;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.nav-icon-image {
  display: block;
  width: 34rpx;
  height: 34rpx;
}

.merchant-content {
  position: relative;
  z-index: 2;
  padding: 0 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.glass-panel,
.warm-glass {
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(255, 248, 238, 0.64));
  box-shadow:
    0 20rpx 56rpx rgba(126, 90, 45, 0.13),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95),
    inset 0 -18rpx 42rpx rgba(255, 226, 191, 0.1);
  -webkit-backdrop-filter: blur(22px) saturate(150%);
  backdrop-filter: blur(22px) saturate(150%);
}

.state-card,
.empty-card {
  margin-top: 30rpx;
  padding: 76rpx 38rpx;
  border-radius: 34rpx;
  text-align: center;
}

.state-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255, 111, 72, 0.14), rgba(255, 255, 255, 0.5));
}

.state-mark.is-warning {
  background: linear-gradient(145deg, rgba(239, 63, 56, 0.14), rgba(255, 255, 255, 0.52));
}

.state-icon-image {
  display: block;
  width: 44rpx;
  height: 44rpx;
}

.state-title {
  color: #2b211b;
  font-size: 34rpx;
  font-weight: 900;
}

.state-desc {
  max-width: 520rpx;
  margin: 14rpx auto 0;
  color: #7a6a5e;
  font-size: 24rpx;
  line-height: 1.55;
}

.primary-button,
.secondary-button,
.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.primary-button {
  background: linear-gradient(145deg, #ff6640 0%, #f2382a 52%, #e92425 100%);
  box-shadow: 0 14rpx 30rpx rgba(226, 49, 37, 0.22), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.28);
  color: #fffaf4;
}

.secondary-button {
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.88), rgba(255, 248, 238, 0.72));
  box-shadow: 0 14rpx 32rpx rgba(126, 90, 45, 0.11), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  color: #ef3f38;
}

.ghost-button {
  border: 1rpx solid rgba(126, 90, 45, 0.12);
  background: rgba(255, 255, 255, 0.54);
  color: #7a6a5e;
}

.state-button {
  min-width: 220rpx;
  margin: 28rpx auto 0;
  padding: 0 36rpx;
}

.state-secondary {
  width: 220rpx;
  margin: 18rpx auto 0;
}

.page-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 34rpx;
}

.hero-kicker {
  color: #ef5a32;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 10rpx;
  color: #2b211b;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 10rpx;
  color: #7a6a5e;
  font-size: 23rpx;
  line-height: 1.45;
}

.hero-button {
  width: 176rpx;
  flex: none;
}

.refresh-tip {
  margin: 22rpx 6rpx 0;
  color: #8c7a6d;
  font-size: 22rpx;
}

.merchant-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 24rpx;
}

.merchant-card {
  padding: 28rpx;
  border-radius: 32rpx;
}

.merchant-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.merchant-title-wrap {
  min-width: 0;
}

.merchant-name {
  color: #2b211b;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.merchant-id {
  margin-top: 8rpx;
  color: #8c7a6d;
  font-size: 22rpx;
  word-break: break-all;
}

.status-tag {
  flex: none;
  height: 40rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.status-tag.is-active {
  background: rgba(67, 160, 71, 0.14);
  color: #43a047;
}

.status-tag.is-disabled {
  background: rgba(126, 90, 45, 0.1);
  color: #8c7a6d;
}

.merchant-meta {
  margin-top: 22rpx;
  border-top: 1rpx solid rgba(126, 90, 45, 0.08);
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(126, 90, 45, 0.06);
}

.meta-row:last-child {
  border-bottom: 0;
}

.meta-label {
  flex: none;
  color: #8c7a6d;
  font-size: 23rpx;
}

.meta-value {
  min-width: 0;
  color: #2b211b;
  font-size: 24rpx;
  font-weight: 700;
  text-align: right;
  word-break: break-all;
}

.merchant-notice {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 238, 0.7);
  color: #7a6a5e;
  font-size: 23rpx;
  line-height: 1.5;
}

.merchant-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-button {
  width: 0;
  flex: 1;
  min-width: 0;
  height: 68rpx;
  font-size: 24rpx;
}

.ghost-button.is-enable {
  color: #43a047;
}

.ghost-button.is-disable {
  color: #8c5e58;
}

.form-mask {
  position: fixed;
  z-index: 40;
  inset: 0;
  display: flex;
  align-items: flex-end;
  padding: 28rpx;
  background: rgba(43, 33, 27, 0.32);
}

.merchant-form {
  box-sizing: border-box;
  width: 100%;
  max-height: 86vh;
  overflow-y: auto;
  padding: 30rpx;
  border-radius: 36rpx;
}

.form-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.form-kicker {
  color: #ef5a32;
  font-size: 19rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.form-title {
  margin-top: 8rpx;
  color: #2b211b;
  font-size: 34rpx;
  font-weight: 900;
}

.form-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(126, 90, 45, 0.08);
  color: #7a6a5e;
  font-size: 36rpx;
  font-weight: 500;
}

.form-field {
  margin-top: 20rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #2b211b;
  font-size: 24rpx;
  font-weight: 800;
}

.field-input,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  border: 1rpx solid rgba(126, 90, 45, 0.1);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.74);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
  color: #2b211b;
  font-size: 25rpx;
}

.field-input {
  height: 76rpx;
  padding: 0 22rpx;
}

.field-input.is-readonly {
  color: #8c7a6d;
  background: rgba(255, 248, 238, 0.66);
}

.field-textarea {
  min-height: 132rpx;
  padding: 20rpx 22rpx;
  line-height: 1.45;
}

.field-help {
  margin-top: 8rpx;
  color: #9b8a7c;
  font-size: 21rpx;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.form-button {
  width: 0;
  flex: 1;
  min-width: 0;
}
