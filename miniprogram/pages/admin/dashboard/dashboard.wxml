<view class="admin-dashboard-page">
  <view class="background-shade"></view>

  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navigationHeight}}px;">
    <view class="nav-back" bindtap="goBack">
      <image class="nav-icon-image" src="/images/icons/icon-back.svg" mode="aspectFit"></image>
    </view>
    <view class="nav-title">系统管理</view>
  </view>

  <view class="admin-content" style="padding-top: {{statusBarHeight + navigationHeight + 16}}px;">
    <view wx:if="{{pageStatus === 'loading'}}" class="state-card glass-panel">
      <view class="state-mark">
        <image class="state-icon-image" src="/images/icons/icon-clock.svg" mode="aspectFit"></image>
      </view>
      <view class="state-title">正在确认系统管理身份</view>
      <view class="state-desc">请稍候，正在检查当前账号是否具备超级管理员权限。</view>
    </view>

    <view wx:elif="{{pageStatus === 'no_permission'}}" class="state-card glass-panel">
      <view class="state-mark is-warning">
        <image class="state-icon-image" src="/images/icons/icon-warning.svg" mode="aspectFit"></image>
      </view>
      <view class="state-title">没有系统管理权限</view>
      <view class="state-desc">当前账号不是超级管理员，无法进入系统管理后台。</view>
      <button class="state-button" bindtap="goHome">返回首页</button>
    </view>

    <view wx:elif="{{pageStatus === 'error'}}" class="state-card glass-panel">
      <view class="state-mark is-warning">
        <image class="state-icon-image" src="/images/icons/icon-warning.svg" mode="aspectFit"></image>
      </view>
      <view class="state-title">身份加载失败</view>
      <view class="state-desc">{{errorMessage}}</view>
      <button class="state-button" bindtap="loadAdminProfile">重新加载</button>
      <button class="secondary-button state-secondary" bindtap="goHome">返回首页</button>
    </view>

    <block wx:else>
      <view class="admin-hero glass-panel">
        <view>
          <view class="hero-kicker">SYSTEM ADMIN</view>
          <view class="hero-title">系统管理</view>
          <view class="hero-desc">超级管理员身份已确认，后续系统级管理能力将在这里逐步开放。</view>
        </view>
        <view class="hero-badge">v0.4-D</view>
      </view>

      <view class="profile-card warm-glass">
        <view class="profile-row">
          <view class="profile-label">当前身份</view>
          <view class="profile-value">super admin</view>
        </view>
        <view class="profile-row">
          <view class="profile-label">OpenID</view>
          <view class="profile-value">{{profile.masked_openid}}</view>
        </view>
        <view class="profile-row">
          <view class="profile-label">版本</view>
          <view class="profile-value">Private Kitchen v0.4-D</view>
        </view>
      </view>

      <view class="section-header">
        <view>
          <view class="section-title is-compact">数据概览</view>
          <view class="section-subtitle">只读统计，不会修改业务数据</view>
        </view>
        <button class="refresh-button" bindtap="refreshOverview">刷新</button>
      </view>

      <view wx:if="{{overviewStatus === 'loading'}}" class="overview-state warm-glass">
        <view class="overview-state-title">正在加载后台数据概览</view>
        <view class="overview-state-desc">请稍候，正在读取商户、餐品、订单和备料相关数据。</view>
      </view>

      <view wx:elif="{{overviewStatus === 'error'}}" class="overview-state warm-glass">
        <view class="overview-state-title">数据概览加载失败</view>
        <view class="overview-state-desc">{{overviewErrorMessage}}</view>
        <button class="mini-button" bindtap="refreshOverview">重新加载</button>
      </view>

      <block wx:else>
        <view class="overview-grid">
          <view
            wx:for="{{overviewCards}}"
            wx:key="title"
            class="overview-card warm-glass theme-{{item.theme}}"
          >
            <view class="overview-card-title">{{item.title}}</view>
            <view class="overview-card-value">{{item.value}}</view>
            <view class="overview-card-desc">{{item.desc}}</view>
          </view>
        </view>

        <view class="overview-meta">最近更新：{{overviewUpdatedAt}}</view>

        <view class="warning-panel warm-glass">
          <view class="panel-heading">风险提醒</view>
          <view wx:if="{{warnings.length === 0}}" class="panel-empty">暂无需要特别关注的数据。</view>
          <view wx:else class="warning-list">
            <view wx:for="{{warnings}}" wx:key="id" class="warning-item">
              <view class="warning-main">
                <view class="warning-title">{{item.title}}</view>
                <view class="warning-desc">{{item.desc}}</view>
              </view>
              <view class="warning-count">{{item.count}}</view>
            </view>
          </view>
        </view>

        <view class="recent-panel warm-glass">
          <view class="panel-heading">最近订单</view>
          <view wx:if="{{recentOrders.length === 0}}" class="panel-empty">暂无最近订单。</view>
          <view wx:else class="recent-list">
            <view wx:for="{{recentOrders}}" wx:key="id" class="recent-item">
              <view class="recent-main">
                <view class="recent-no">{{item.order_no}}</view>
                <view class="recent-time">{{item.created_at_text}} · {{item.item_count}} 件</view>
              </view>
              <view class="recent-side">
                <view class="recent-status">{{item.status_text}}</view>
                <view class="recent-amount">{{item.total_amount_text}}</view>
              </view>
            </view>
          </view>
        </view>
      </block>

      <view class="section-title">后台模块</view>
      <view class="module-grid">
        <view
          wx:for="{{modules}}"
          wx:key="title"
          class="module-card warm-glass {{item.action ? 'is-clickable' : 'is-disabled'}}"
          data-action="{{item.action}}"
          bindtap="handleModuleTap"
        >
          <view class="module-tag">{{item.tag}}</view>
          <view class="module-title">{{item.title}}</view>
          <view class="module-desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="action-row">
        <button class="secondary-button" bindtap="goHome">返回首页</button>
        <button class="state-button action-primary" bindtap="goMerchantDashboard">返回商家工作台</button>
      </view>
    </block>
  </view>
</view>
