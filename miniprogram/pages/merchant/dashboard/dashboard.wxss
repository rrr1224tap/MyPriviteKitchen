page {
  min-height: 100%;
  background: #fbf3ea;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.merchant-dashboard-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #2b211b;
  background:
    radial-gradient(circle at 16% 0%, rgba(255, 255, 255, 0.94), transparent 270rpx),
    radial-gradient(circle at 88% 4%, rgba(255, 214, 162, 0.28), transparent 360rpx),
    linear-gradient(180deg, #fff7ed 0%, #f7efe6 55%, #fbf6ef 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 52vh;
  opacity: 0.08;
  filter: blur(8rpx) saturate(1.04);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 249, 241, 0.92) 0%, rgba(247, 239, 230, 0.86) 46%, rgba(251, 246, 239, 0.98) 100%),
    radial-gradient(circle at 50% 18%, rgba(255, 206, 145, 0.24), transparent 44%);
}

.custom-nav {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  left: 0;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  bottom: 10rpx;
  left: 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 50%;
  background: rgba(255, 250, 244, 0.72);
  box-shadow: 0 12rpx 28rpx rgba(126, 90, 45, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  color: #6d584a;
  font-family: serif;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  text-align: center;
  pointer-events: auto;
  -webkit-backdrop-filter: blur(18px) saturate(145%);
  backdrop-filter: blur(18px) saturate(145%);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #2b211b;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.dashboard-content {
  position: relative;
  z-index: 2;
  padding: 0 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.glass-panel,
.warm-glass {
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(255, 248, 238, 0.64));
  box-shadow:
    0 20rpx 56rpx rgba(126, 90, 45, 0.13),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95),
    inset 0 -18rpx 42rpx rgba(255, 226, 191, 0.1);
  -webkit-backdrop-filter: blur(22px) saturate(150%);
  backdrop-filter: blur(22px) saturate(150%);
}

.state-card {
  margin-top: 30rpx;
  padding: 76rpx 38rpx;
  border-radius: 34rpx;
  text-align: center;
}

.state-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255, 111, 72, 0.14), rgba(255, 255, 255, 0.5));
}

.state-icon-image {
  display: block;
  width: 44rpx;
  height: 44rpx;
}

.state-title {
  color: #2b211b;
  font-size: 34rpx;
  font-weight: 900;
}

.state-desc {
  max-width: 520rpx;
  margin: 14rpx auto 0;
  color: #7a6a5e;
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 220rpx;
  height: 72rpx;
  margin-top: 28rpx;
  padding: 0 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff6640 0%, #f2382a 52%, #e92425 100%);
  box-shadow: 0 14rpx 30rpx rgba(226, 49, 37, 0.22), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.28);
  color: #fffaf4;
  font-size: 25rpx;
  font-weight: 800;
}

.merchant-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 34rpx;
}

.hero-kicker,
.section-kicker {
  color: #ef5a32;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 10rpx;
  color: #2b211b;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 10rpx;
  color: #7a6a5e;
  font-size: 23rpx;
  line-height: 1.45;
}

.hero-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(145deg, #ff9b39 0%, #ff6b2c 100%);
  box-shadow: 0 14rpx 30rpx rgba(240, 120, 34, 0.22), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.28);
  color: #fff7ed;
  font-size: 24rpx;
  font-weight: 800;
}

.entry-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 26rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  color: #2a211d;
}

.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  flex: none;
  border-radius: 26rpx;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 12rpx 26rpx rgba(226, 49, 37, 0.18), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.28);
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
}

.entry-copy {
  min-width: 0;
  flex: 1;
}

.entry-title {
  color: #2a211d;
  font-size: 31rpx;
  font-weight: 900;
}

.entry-desc {
  margin-top: 8rpx;
  color: #7a6a5e;
  font-size: 22rpx;
  line-height: 1.45;
}

.entry-arrow {
  flex: none;
  color: #ef5a32;
  font-size: 34rpx;
  font-weight: 800;
}

.tips-panel {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255, 252, 247, 0.82), rgba(255, 243, 229, 0.58));
}

.section-title {
  margin-top: 8rpx;
  color: #2b211b;
  font-size: 30rpx;
  font-weight: 800;
}

.tip-row {
  margin-top: 18rpx;
  color: #7a6a5e;
  font-size: 23rpx;
  line-height: 1.5;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  margin-top: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.88), rgba(255, 248, 238, 0.72));
  box-shadow: 0 14rpx 32rpx rgba(126, 90, 45, 0.11), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  color: #ef3f38;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 76rpx;
}

.nav-icon-image,
.entry-icon-image {
  display: block;
}

.nav-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.entry-icon-image {
  width: 42rpx;
  height: 42rpx;
}
