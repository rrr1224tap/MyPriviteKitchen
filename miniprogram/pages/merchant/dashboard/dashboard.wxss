page {
  min-height: 100%;
  background: #211815;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.merchant-dashboard-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #fffaf4;
  background:
    radial-gradient(circle at 16% 0%, rgba(230, 59, 74, 0.22), transparent 34%),
    radial-gradient(circle at 84% 8%, rgba(255, 202, 128, 0.18), transparent 30%),
    linear-gradient(180deg, #2a1d18 0%, #16100e 52%, #f3e8dc 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 58vh;
  opacity: 0.24;
  filter: blur(1px);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(20, 13, 10, 0.68) 0%, rgba(26, 18, 15, 0.54) 34%, rgba(243, 232, 220, 0.97) 100%),
    radial-gradient(circle at 50% 42%, rgba(255, 229, 188, 0.18), transparent 42%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 50%;
  color: #fff6ea;
  font-family: serif;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  text-align: center;
  pointer-events: auto;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.18);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #fff3dc;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.dashboard-content {
  position: relative;
  z-index: 2;
  padding: 0 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.glass-panel {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 18rpx 42rpx rgba(54, 24, 15, 0.18);
  backdrop-filter: blur(18px);
}

.warm-glass {
  background: rgba(255, 250, 244, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 16rpx 38rpx rgba(61, 39, 25, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18px);
}

.merchant-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  background: rgba(62, 39, 30, 0.74);
}

.hero-kicker,
.section-kicker {
  color: rgba(255, 222, 169, 0.86);
  font-size: 20rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 8rpx;
  color: #fff8ec;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 8rpx;
  color: rgba(255, 246, 230, 0.72);
  font-size: 23rpx;
  line-height: 1.45;
}

.hero-badge {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  color: #fff7ed;
  font-size: 24rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #ff6a72 0%, #e63b4a 100%);
  box-shadow: 0 14rpx 30rpx rgba(230, 59, 74, 0.3);
}

.entry-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  color: #2a211d;
}

.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  flex: none;
  border-radius: 26rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  background: linear-gradient(145deg, #f2494e, #bd111b);
  box-shadow: 0 12rpx 26rpx rgba(181, 9, 17, 0.22);
}

.entry-copy {
  min-width: 0;
  flex: 1;
}

.entry-title {
  color: #2a211d;
  font-size: 31rpx;
  font-weight: 900;
}

.entry-desc {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.56);
  font-size: 22rpx;
  line-height: 1.45;
}

.entry-arrow {
  flex: none;
  color: #e63b4a;
  font-size: 38rpx;
}

.tips-panel {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(61, 48, 41, 0.72);
}

.section-title {
  margin-top: 8rpx;
  color: #fff8ec;
  font-size: 30rpx;
  font-weight: 800;
}

.tip-row {
  margin-top: 18rpx;
  color: rgba(255, 250, 244, 0.74);
  font-size: 23rpx;
  line-height: 1.5;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  margin-top: 30rpx;
  border-radius: 999rpx;
  color: rgba(255, 250, 244, 0.86);
  font-size: 25rpx;
  font-weight: 800;
  line-height: 76rpx;
  background: rgba(61, 48, 41, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.nav-icon-image,
.entry-icon-image {
  display: block;
}

.nav-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.entry-icon-image {
  width: 42rpx;
  height: 42rpx;
}
