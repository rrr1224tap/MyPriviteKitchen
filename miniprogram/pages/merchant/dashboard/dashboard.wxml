<view class="merchant-dashboard-page">
  <image
    wx:if="{{backgroundImageAvailable}}"
    class="background-image-window"
    src="{{backgroundImage}}"
    mode="aspectFill"
    binderror="handleBackgroundImageError"
  />
  <view class="background-shade"></view>

  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navigationHeight}}px;">
    <view class="nav-back" bindtap="goBack"><image class="nav-icon-image" src="/images/icons/icon-back.svg" mode="aspectFit"></image></view>
    <view class="nav-title">商家工作台</view>
  </view>

  <view class="dashboard-content" style="padding-top: {{statusBarHeight + navigationHeight + 16}}px;">
    <view wx:if="{{pageStatus === 'checking'}}" class="state-card glass-panel">
      <view class="state-mark"><image class="state-icon-image" src="/images/icons/icon-clock.svg" mode="aspectFit"></image></view>
      <view class="state-title">正在确认小厨身份</view>
      <view class="state-desc">正在检查当前账号是否已开通商家工作台权限</view>
    </view>

    <view wx:elif="{{pageStatus === 'no_permission'}}" class="state-card glass-panel">
      <view class="state-mark"><image class="state-icon-image" src="/images/icons/icon-warning.svg" mode="aspectFit"></image></view>
      <view class="state-title">需要注册小厨身份</view>
      <view class="state-desc">当前账号暂未开通小厨商家身份，请联系管理员注册 / 开通后再进入商家工作台。</view>
      <button class="state-button" bindtap="goToUserHome">返回首页</button>
    </view>

    <block wx:else>
    <view class="merchant-hero glass-panel">
      <view>
        <view class="hero-kicker">MERCHANT DESK</view>
        <view class="hero-title">订单处理中心</view>
        <view class="hero-desc">查看新订单，完成接单、制作和出餐处理</view>
      </view>
      <view class="hero-badge">MVP</view>
    </view>

    <view class="entry-card warm-glass" bindtap="goToOrders">
      <view class="entry-icon"><image class="entry-icon-image" src="/images/icons/icon-merchant-orders.svg" mode="aspectFit"></image></view>
      <view class="entry-copy">
        <view class="entry-title">进入商家订单</view>
        <view class="entry-desc">查看订单列表，处理待接单、制作中和已完成订单</view>
      </view>
      <view class="entry-arrow">→</view>
    </view>

    <view class="entry-card warm-glass" bindtap="goToPrepSummary">
      <view class="entry-icon"><image class="entry-icon-image" src="/images/icons/icon-dish.svg" mode="aspectFit"></image></view>
      <view class="entry-copy">
        <view class="entry-title">今日备料</view>
        <view class="entry-desc">按今日订单自动汇总食材</view>
      </view>
      <view class="entry-arrow">→</view>
    </view>

    <view class="entry-card warm-glass" bindtap="goToCategories">
      <view class="entry-icon"><image class="entry-icon-image" src="/images/icons/icon-category.svg" mode="aspectFit"></image></view>
      <view class="entry-copy">
        <view class="entry-title">分类管理</view>
        <view class="entry-desc">新增、编辑、停用分类，并调整点餐页展示顺序</view>
      </view>
      <view class="entry-arrow">→</view>
    </view>

    <view class="entry-card warm-glass" bindtap="goToDishes">
      <view class="entry-icon"><image class="entry-icon-image" src="/images/icons/icon-dish.svg" mode="aspectFit"></image></view>
      <view class="entry-copy">
        <view class="entry-title">餐品管理</view>
        <view class="entry-desc">维护餐品信息、价格、上下架和展示顺序</view>
      </view>
      <view class="entry-arrow">→</view>
    </view>

    <view class="tips-panel glass-panel">
      <view class="section-kicker">CHECKLIST</view>
      <view class="section-title">联调提醒</view>
      <view class="tip-row">1. 当前账号需要配置为 merchant_staff active 员工</view>
      <view class="tip-row">2. 真实权限由商家订单云函数校验</view>
      <view class="tip-row">3. 分类和餐品管理已接入，支付后续再接入</view>
    </view>

    <button class="secondary-button" bindtap="goToUserHome">返回用户首页</button>
    </block>
  </view>
</view>
