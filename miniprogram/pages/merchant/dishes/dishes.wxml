<view class="merchant-dishes-page">
  <image
    wx:if="{{backgroundImageAvailable}}"
    class="background-image-window"
    src="{{backgroundImage}}"
    mode="aspectFill"
    binderror="handleBackgroundImageError"
  />
  <view class="background-shade"></view>

  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navigationHeight}}px;">
    <view class="nav-back" bindtap="goBack"><image class="nav-icon-image" src="/images/icons/icon-back.svg" mode="aspectFit"></image></view>
    <view class="nav-title">餐品管理</view>
  </view>

  <scroll-view class="dishes-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="dishes-content" style="padding-top: {{statusBarHeight + navigationHeight + 16}}px;">
      <view class="merchant-hero glass-panel">
        <view class="hero-copy">
          <view class="hero-kicker">MENU DISH</view>
          <view class="hero-title">餐品管理</view>
          <view class="hero-desc">维护餐品信息、价格、上下架和展示顺序</view>
        </view>
        <button class="hero-action" bindtap="handleCreateTap" disabled="{{submitting}}">新增</button>
      </view>

      <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{categoryFilters}}"
            wx:key="category_id"
            class="filter-tab {{activeCategoryId === item.category_id ? 'active' : ''}}"
            data-id="{{item.category_id}}"
            bindtap="handleCategoryFilterTap"
          >{{item.name}}</view>
        </view>
      </scroll-view>

      <scroll-view class="filter-scroll status-filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{statusFilters}}"
            wx:key="value"
            class="filter-tab status-filter {{activeStatus === item.value ? 'active' : ''}}"
            data-status="{{item.value}}"
            bindtap="handleStatusFilterTap"
          >{{item.label}}</view>
        </view>
      </scroll-view>

      <view wx:if="{{pageStatus === 'loading'}}" class="state-card warm-glass">
        <view class="state-mark"><image class="state-icon-image" src="/images/icons/icon-clock.svg" mode="aspectFit"></image></view>
        <view class="state-title">正在加载餐品</view>
        <view class="state-desc">正在同步当前门店的餐品数据</view>
      </view>

      <view wx:elif="{{pageStatus === 'error'}}" class="state-card warm-glass">
        <view class="state-mark"><image class="state-icon-image" src="/images/icons/icon-warning.svg" mode="aspectFit"></image></view>
        <view class="state-title">{{errorTitle || '餐品加载失败'}}</view>
        <view class="state-desc">{{errorMessage}}</view>
        <button wx:if="{{isPermissionError}}" class="state-button" bindtap="goToUserHome">返回首页</button>
        <button wx:else class="state-button" bindtap="retryLoad">重新加载</button>
      </view>

      <view wx:elif="{{pageStatus === 'empty'}}" class="state-card warm-glass">
        <view class="state-mark"><image class="state-icon-image" src="/images/icons/icon-dish.svg" mode="aspectFit"></image></view>
        <view class="state-title">还没有餐品</view>
        <view class="state-desc">先新增一个餐品，上架后会出现在用户点餐菜单中</view>
        <button class="state-button" bindtap="handleCreateTap" disabled="{{submitting}}">新增餐品</button>
      </view>

      <view wx:else class="dish-list">
        <view
          wx:for="{{dishes}}"
          wx:key="dish_id"
          class="dish-card warm-glass {{item.status === 'on_sale' ? '' : 'dish-card-muted'}}"
        >
          <view class="dish-main">
            <image
              wx:if="{{item.image_url && !item.image_failed}}"
              class="dish-image"
              src="{{item.image_url}}"
              mode="aspectFill"
              data-id="{{item.dish_id}}"
              binderror="handleDishImageError"
            />
            <view wx:else class="dish-image dish-image-fallback"><image class="dish-placeholder-image" src="{{foodPlaceholderImage}}" mode="aspectFit"></image></view>
            <view class="dish-copy">
              <view class="dish-head">
                <view class="dish-name">{{item.name}}</view>
                <view class="dish-status {{item.status_class}}">{{item.status_text}}</view>
              </view>
              <view class="dish-desc">{{item.description || '暂无简介'}}</view>
              <view class="dish-meta">
                <view class="meta-pill">{{item.category_name}}</view>
                <view class="meta-pill">排序 {{item.sort_order}}</view>
                <view class="meta-pill stock-pill {{item.stock_class}}">{{item.stock_text}}</view>
              </view>
              <view class="dish-tags" wx:if="{{item.tags.length}}">
                <view wx:for="{{item.tags}}" wx:key="*this" class="dish-tag">{{item}}</view>
              </view>
            </view>
          </view>

          <view class="dish-foot">
            <view>
              <view class="price-text">¥{{item.price_yuan}}</view>
              <view wx:if="{{item.original_price_yuan}}" class="original-price">原价 ¥{{item.original_price_yuan}}</view>
            </view>
            <view class="action-row">
              <button
                class="action-button ghost"
                data-index="{{index}}"
                data-direction="-1"
                bindtap="handleMoveTap"
                disabled="{{submitting || index === 0}}"
              >上移</button>
              <button
                class="action-button ghost"
                data-index="{{index}}"
                data-direction="1"
                bindtap="handleMoveTap"
                disabled="{{submitting || index === dishes.length - 1}}"
              >下移</button>
              <button
                class="action-button"
                data-id="{{item.dish_id}}"
                bindtap="handleEditTap"
                disabled="{{submitting}}"
              >编辑</button>
              <button
                wx:if="{{item.status === 'on_sale'}}"
                class="action-button danger"
                data-id="{{item.dish_id}}"
                data-action="offSale"
                bindtap="handleStatusTap"
                disabled="{{submitting}}"
              >下架</button>
              <button
                wx:else
                class="action-button"
                data-id="{{item.dish_id}}"
                data-action="onSale"
                bindtap="handleStatusTap"
                disabled="{{submitting}}"
              >上架</button>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{formVisible}}" class="form-mask">
    <view class="dish-form warm-glass">
      <view class="form-head">
        <view>
          <view class="form-kicker">DISH FORM</view>
          <view class="form-title">{{formTitle}}</view>
        </view>
        <view class="form-close" bindtap="closeForm">×</view>
      </view>

      <scroll-view class="form-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="form-field">
          <view class="field-label">餐品名称</view>
          <input class="field-input" value="{{formData.name}}" data-field="name" bindinput="handleFormInput" placeholder="例如：招牌肥牛石锅拌饭" />
        </view>

        <view class="form-field">
          <view class="field-label">所属分类</view>
          <picker range="{{formCategoryOptions}}" range-key="name" value="{{formCategoryIndex}}" bindchange="handleFormCategoryChange">
            <view class="field-picker">{{formData.category_name || '请选择分类'}}</view>
          </picker>
        </view>

        <view class="form-field">
          <view class="field-label">简介</view>
          <input class="field-input" value="{{formData.description}}" data-field="description" bindinput="handleFormInput" placeholder="用于菜单卡片展示" />
        </view>

        <view class="form-field">
          <view class="field-label">详情</view>
          <textarea class="field-textarea" value="{{formData.detail_description}}" data-field="detail_description" bindinput="handleFormInput" placeholder="用于餐品详情页展示" maxlength="120"></textarea>
        </view>

        <view class="form-field">
          <view class="field-label">餐品主图</view>
          <view class="image-upload-card">
            <image
              wx:if="{{formData.image_url && formImageAvailable}}"
              class="image-upload-preview"
              src="{{formData.image_url}}"
              mode="aspectFill"
              bindtap="previewFormImage"
              binderror="handleFormImageError"
            />
            <view wx:else class="image-upload-placeholder" bindtap="chooseDishImage">
              <image class="image-upload-placeholder-image" src="{{foodPlaceholderImage}}" mode="aspectFit"></image>
              <view class="image-upload-title">上传餐品图片</view>
              <view class="image-upload-desc">支持从相册选择或拍照</view>
            </view>

            <view class="image-upload-footer">
              <button
                class="image-upload-button"
                bindtap="chooseDishImage"
                disabled="{{uploadingImage}}"
              >{{uploadingImage ? '上传中...' : (formData.image_url ? '更换图片' : '上传图片')}}</button>
              <view class="image-upload-tip">上传成功后会自动填入图片地址</view>
            </view>
          </view>
        </view>

        <view class="form-field">
          <view class="field-label">图片地址</view>
          <input class="field-input" value="{{formData.image_url}}" data-field="image_url" bindinput="handleFormInput" placeholder="可手动粘贴 cloud:// fileID 调试" />
        </view>

        <view class="form-grid">
          <view class="form-field">
            <view class="field-label">售价（元）</view>
            <input class="field-input" type="digit" value="{{formData.price_yuan}}" data-field="price_yuan" bindinput="handleFormInput" placeholder="29.90" />
          </view>

          <view class="form-field">
            <view class="field-label">原价（元）</view>
            <input class="field-input" type="digit" value="{{formData.original_price_yuan}}" data-field="original_price_yuan" bindinput="handleFormInput" placeholder="可不填" />
          </view>
        </view>

        <view class="form-grid">
          <view class="form-field">
            <view class="field-label">标签</view>
            <input class="field-input" value="{{formData.tags_text}}" data-field="tags_text" bindinput="handleFormInput" placeholder="招牌，热销" />
          </view>

          <view class="form-field">
            <view class="field-label">排序</view>
            <input class="field-input" type="number" value="{{formData.sort_order}}" data-field="sort_order" bindinput="handleFormInput" placeholder="1" />
          </view>
        </view>

        <view class="stock-panel">
          <view class="stock-panel-head">
            <view>
              <view class="field-label">库存 / 售罄</view>
              <view class="stock-panel-desc">用于控制用户端是否可加购，下架状态仍由上架/下架按钮控制</view>
            </view>
          </view>

          <view class="switch-row">
            <view>
              <view class="switch-title">启用库存管理</view>
              <view class="switch-desc">关闭后显示不限库存，不参与库存扣减</view>
            </view>
            <switch
              checked="{{formData.stock_enabled}}"
              color="#E63B4A"
              data-field="stock_enabled"
              bindchange="handleFormSwitchChange"
            />
          </view>

          <view class="form-field stock-count-field">
            <view class="field-label">库存数量</view>
            <input class="field-input" type="number" value="{{formData.stock_count}}" data-field="stock_count" bindinput="handleFormInput" placeholder="0" />
          </view>

          <view class="switch-row">
            <view>
              <view class="switch-title">手动售罄</view>
              <view class="switch-desc">开启后用户端显示已售罄，不能加购</view>
            </view>
            <switch
              checked="{{formData.sold_out}}"
              color="#E63B4A"
              data-field="sold_out"
              bindchange="handleFormSwitchChange"
            />
          </view>
        </view>

        <view class="option-panel">
          <view class="option-panel-head">
            <view>
              <view class="field-label">规格配置</view>
              <view class="option-panel-desc">用于标准份、大份等规格选择，第一阶段按单选规格保存</view>
            </view>
            <button
              class="option-add-button"
              data-type="spec"
              bindtap="handleAddOptionGroup"
            >添加规格</button>
          </view>

          <view wx:if="{{!formData.spec_groups.length}}" class="option-empty">
            暂无规格配置，可先保存为空
          </view>

          <view
            wx:for="{{formData.spec_groups}}"
            wx:for-item="group"
            wx:for-index="groupIndex"
            wx:key="group_id"
            class="option-group-card"
          >
            <view class="option-group-head">
              <view class="option-group-title">规格组 {{groupIndex + 1}}</view>
              <button
                class="option-remove-button"
                data-type="spec"
                data-group-index="{{groupIndex}}"
                bindtap="handleRemoveOptionGroup"
              >删除</button>
            </view>

            <view class="form-field">
              <view class="field-label">规格组名称</view>
              <input
                class="field-input"
                value="{{group.name}}"
                data-type="spec"
                data-group-index="{{groupIndex}}"
                data-field="name"
                bindinput="handleOptionGroupInput"
                placeholder="例如：份量"
              />
            </view>

            <view
              wx:for="{{group.options}}"
              wx:for-item="option"
              wx:for-index="optionIndex"
              wx:key="option_id"
              class="option-item-card"
            >
              <view class="option-item-head">
                <view class="option-item-title">规格项 {{optionIndex + 1}}</view>
                <button
                  class="option-remove-button small"
                  data-type="spec"
                  data-group-index="{{groupIndex}}"
                  data-option-index="{{optionIndex}}"
                  bindtap="handleRemoveOption"
                >删除</button>
              </view>

              <view class="form-grid">
                <view class="form-field">
                  <view class="field-label">规格名称</view>
                  <input
                    class="field-input"
                    value="{{option.name}}"
                    data-type="spec"
                    data-group-index="{{groupIndex}}"
                    data-option-index="{{optionIndex}}"
                    data-field="name"
                    bindinput="handleOptionInput"
                    placeholder="例如：大份"
                  />
                </view>

                <view class="form-field">
                  <view class="field-label">加价（元）</view>
                  <input
                    class="field-input"
                    type="digit"
                    value="{{option.price_delta_yuan}}"
                    data-type="spec"
                    data-group-index="{{groupIndex}}"
                    data-option-index="{{optionIndex}}"
                    data-field="price_delta_yuan"
                    bindinput="handleOptionInput"
                    placeholder="0.00"
                  />
                </view>
              </view>

              <view class="switch-row option-switch-row">
                <view>
                  <view class="switch-title">启用该规格项</view>
                  <view class="switch-desc">关闭后用户端不会展示该规格项</view>
                </view>
                <switch
                  checked="{{option.enabled}}"
                  color="#43A047"
                  data-type="spec"
                  data-group-index="{{groupIndex}}"
                  data-option-index="{{optionIndex}}"
                  bindchange="handleOptionSwitchChange"
                />
              </view>
            </view>

            <button
              class="option-add-sub-button"
              data-type="spec"
              data-group-index="{{groupIndex}}"
              bindtap="handleAddOption"
            >添加规格项</button>
          </view>
        </view>

        <view class="option-panel">
          <view class="option-panel-head">
            <view>
              <view class="field-label">加料配置</view>
              <view class="option-panel-desc">用于加蛋、加肥牛等可选加料，不影响原有规格配置</view>
            </view>
            <button
              class="option-add-button"
              data-type="addon"
              bindtap="handleAddOptionGroup"
            >添加加料</button>
          </view>

          <view wx:if="{{!formData.addon_groups.length}}" class="option-empty">
            暂无加料配置，可先保存为空
          </view>

          <view
            wx:for="{{formData.addon_groups}}"
            wx:for-item="group"
            wx:for-index="groupIndex"
            wx:key="group_id"
            class="option-group-card"
          >
            <view class="option-group-head">
              <view class="option-group-title">加料组 {{groupIndex + 1}}</view>
              <button
                class="option-remove-button"
                data-type="addon"
                data-group-index="{{groupIndex}}"
                bindtap="handleRemoveOptionGroup"
              >删除</button>
            </view>

            <view class="form-grid">
              <view class="form-field">
                <view class="field-label">加料组名称</view>
                <input
                  class="field-input"
                  value="{{group.name}}"
                  data-type="addon"
                  data-group-index="{{groupIndex}}"
                  data-field="name"
                  bindinput="handleOptionGroupInput"
                  placeholder="例如：加料"
                />
              </view>

              <view class="form-field">
                <view class="field-label">最多可选</view>
                <input
                  class="field-input"
                  type="number"
                  value="{{group.max_select}}"
                  data-type="addon"
                  data-group-index="{{groupIndex}}"
                  data-field="max_select"
                  bindinput="handleOptionGroupInput"
                  placeholder="3"
                />
              </view>
            </view>

            <view
              wx:for="{{group.options}}"
              wx:for-item="option"
              wx:for-index="optionIndex"
              wx:key="option_id"
              class="option-item-card"
            >
              <view class="option-item-head">
                <view class="option-item-title">加料项 {{optionIndex + 1}}</view>
                <button
                  class="option-remove-button small"
                  data-type="addon"
                  data-group-index="{{groupIndex}}"
                  data-option-index="{{optionIndex}}"
                  bindtap="handleRemoveOption"
                >删除</button>
              </view>

              <view class="form-grid">
                <view class="form-field">
                  <view class="field-label">加料名称</view>
                  <input
                    class="field-input"
                    value="{{option.name}}"
                    data-type="addon"
                    data-group-index="{{groupIndex}}"
                    data-option-index="{{optionIndex}}"
                    data-field="name"
                    bindinput="handleOptionInput"
                    placeholder="例如：加蛋"
                  />
                </view>

                <view class="form-field">
                  <view class="field-label">加价（元）</view>
                  <input
                    class="field-input"
                    type="digit"
                    value="{{option.price_delta_yuan}}"
                    data-type="addon"
                    data-group-index="{{groupIndex}}"
                    data-option-index="{{optionIndex}}"
                    data-field="price_delta_yuan"
                    bindinput="handleOptionInput"
                    placeholder="2.00"
                  />
                </view>
              </view>

              <view class="switch-row option-switch-row">
                <view>
                  <view class="switch-title">启用该加料项</view>
                  <view class="switch-desc">关闭后用户端不会展示该加料项</view>
                </view>
                <switch
                  checked="{{option.enabled}}"
                  color="#43A047"
                  data-type="addon"
                  data-group-index="{{groupIndex}}"
                  data-option-index="{{optionIndex}}"
                  bindchange="handleOptionSwitchChange"
                />
              </view>
            </view>

            <button
              class="option-add-sub-button"
              data-type="addon"
              data-group-index="{{groupIndex}}"
              bindtap="handleAddOption"
            >添加加料项</button>
          </view>
        </view>

        <view class="ingredient-panel">
          <view class="ingredient-panel-head">
            <view>
              <view class="field-label">食材配置</view>
              <view class="ingredient-panel-desc">用于后续备料汇总，普通用户不可见</view>
            </view>
            <button
              class="ingredient-add-button"
              bindtap="handleAddIngredient"
            >添加食材</button>
          </view>

          <view wx:if="{{!formData.ingredients.length}}" class="ingredient-empty">
            暂无食材配置，可先保存为空
          </view>

          <view
            wx:for="{{formData.ingredients}}"
            wx:key="sort_order"
            class="ingredient-card"
          >
            <view class="ingredient-card-head">
              <view class="ingredient-card-title">食材 {{index + 1}}</view>
              <button
                class="ingredient-remove-button"
                data-index="{{index}}"
                bindtap="handleRemoveIngredient"
              >删除</button>
            </view>

            <view class="form-field">
              <view class="field-label">食材名称</view>
              <input
                class="field-input"
                value="{{item.name}}"
                maxlength="30"
                data-index="{{index}}"
                data-field="name"
                bindinput="handleIngredientInput"
                placeholder="例如：牛肉片"
              />
            </view>

            <view class="form-grid">
              <view class="form-field">
                <view class="field-label">每份用量</view>
                <input
                  class="field-input"
                  type="digit"
                  value="{{item.amount}}"
                  data-index="{{index}}"
                  data-field="amount"
                  bindinput="handleIngredientInput"
                  placeholder="150"
                />
              </view>

              <view class="form-field">
                <view class="field-label">单位</view>
                <input
                  class="field-input"
                  value="{{item.unit}}"
                  maxlength="10"
                  data-index="{{index}}"
                  data-field="unit"
                  bindinput="handleIngredientInput"
                  placeholder="g"
                />
              </view>
            </view>

            <view class="form-field">
              <view class="field-label">食材分类</view>
              <input
                class="field-input"
                value="{{item.category}}"
                maxlength="12"
                data-index="{{index}}"
                data-field="category"
                bindinput="handleIngredientInput"
                placeholder="例如：肉类"
              />
            </view>

            <view class="form-field">
              <view class="field-label">备注</view>
              <textarea
                class="field-textarea"
                value="{{item.note}}"
                maxlength="80"
                data-index="{{index}}"
                data-field="note"
                bindinput="handleIngredientInput"
                placeholder="例如：可用肥牛卷替代"
              ></textarea>
            </view>

            <view class="switch-row ingredient-switch-row">
              <view>
                <view class="switch-title">启用该食材</view>
                <view class="switch-desc">关闭后后续备料汇总不会统计该食材</view>
              </view>
              <switch
                checked="{{item.enabled}}"
                color="#43A047"
                data-index="{{index}}"
                bindchange="handleIngredientSwitchChange"
              />
            </view>
          </view>
        </view>

        <view class="tutorial-panel">
          <view class="tutorial-panel-head">
            <view>
              <view class="field-label">做法参考</view>
              <view class="tutorial-panel-desc">最多 3 条，仅商家端备料和做菜时查看</view>
            </view>
            <button
              class="tutorial-add-button"
              bindtap="handleAddTutorial"
              disabled="{{formData.tutorials.length >= 3}}"
            >添加</button>
          </view>

          <view wx:if="{{!formData.tutorials.length}}" class="tutorial-empty">
            暂无做法参考，可先保存为空
          </view>

          <view
            wx:for="{{formData.tutorials}}"
            wx:key="sort_order"
            class="tutorial-card"
          >
            <view class="tutorial-card-head">
              <view class="tutorial-card-title">做法参考 {{index + 1}}</view>
              <button
                class="tutorial-remove-button"
                data-index="{{index}}"
                bindtap="handleRemoveTutorial"
              >删除</button>
            </view>

            <view class="form-field">
              <view class="field-label">教程标题</view>
              <input
                class="field-input"
                value="{{item.title}}"
                maxlength="30"
                data-index="{{index}}"
                data-field="title"
                bindinput="handleTutorialInput"
                placeholder="例如：韩式牛肉拌饭做法"
              />
            </view>

            <view class="form-field">
              <view class="field-label">平台类型</view>
              <picker
                range="{{tutorialPlatformOptions}}"
                range-key="label"
                value="{{item.platform_index}}"
                data-index="{{index}}"
                bindchange="handleTutorialPlatformChange"
              >
                <view class="field-picker">{{item.platform_text || '其他'}}</view>
              </picker>
            </view>

            <view class="form-field">
              <view class="field-label">链接 / 口令</view>
              <textarea
                class="field-textarea tutorial-textarea"
                value="{{item.url}}"
                maxlength="500"
                data-index="{{index}}"
                data-field="url"
                bindinput="handleTutorialInput"
                placeholder="可粘贴抖音口令、分享链接或文字路径"
              ></textarea>
            </view>

            <view class="form-field">
              <view class="field-label">备注</view>
              <textarea
                class="field-textarea"
                value="{{item.note}}"
                maxlength="80"
                data-index="{{index}}"
                data-field="note"
                bindinput="handleTutorialInput"
                placeholder="例如：重点看酱料比例"
              ></textarea>
            </view>

            <view class="switch-row tutorial-switch-row">
              <view>
                <view class="switch-title">启用该参考</view>
                <view class="switch-desc">关闭后订单详情中不会展示</view>
              </view>
              <switch
                checked="{{item.enabled}}"
                color="#43A047"
                data-index="{{index}}"
                bindchange="handleTutorialSwitchChange"
              />
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="form-actions">
        <button class="form-button secondary" bindtap="closeForm" disabled="{{submitting}}">取消</button>
        <button class="form-button primary" bindtap="submitForm" disabled="{{submitting}}">{{submitting ? '保存中...' : '保存'}}</button>
      </view>
    </view>
  </view>
</view>
