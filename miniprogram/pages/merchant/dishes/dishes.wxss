page {
  min-height: 100%;
  background: #fbf3ea;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

input,
textarea {
  box-sizing: border-box;
}

.merchant-dishes-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #2b211b;
  background:
    radial-gradient(circle at 16% 0%, rgba(255, 255, 255, 0.94), transparent 270rpx),
    radial-gradient(circle at 88% 4%, rgba(255, 214, 162, 0.28), transparent 360rpx),
    linear-gradient(180deg, #fff7ed 0%, #f7efe6 55%, #fbf6ef 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 52vh;
  opacity: 0.08;
  filter: blur(8rpx) saturate(1.04);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 249, 241, 0.92) 0%, rgba(247, 239, 230, 0.86) 46%, rgba(251, 246, 239, 0.98) 100%),
    radial-gradient(circle at 50% 18%, rgba(255, 206, 145, 0.24), transparent 44%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 50%;
  color: #6d584a;
  font-family: serif;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  text-align: center;
  pointer-events: auto;
  background: rgba(255, 250, 244, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 28rpx rgba(126, 90, 45, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  -webkit-backdrop-filter: blur(18px) saturate(145%);
  backdrop-filter: blur(18px) saturate(145%);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #2b211b;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.dishes-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.dishes-content {
  padding: 0 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.glass-panel,
.warm-glass {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(255, 248, 238, 0.64));
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow:
    0 20rpx 56rpx rgba(126, 90, 45, 0.13),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95),
    inset 0 -18rpx 42rpx rgba(255, 226, 191, 0.1);
  -webkit-backdrop-filter: blur(22px) saturate(150%);
  backdrop-filter: blur(22px) saturate(150%);
}

.merchant-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 34rpx;
}

.hero-copy {
  min-width: 0;
}

.hero-kicker,
.form-kicker {
  color: #ef5a32;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 8rpx;
  color: #2b211b;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 8rpx;
  color: #7a6a5e;
  font-size: 23rpx;
  line-height: 1.45;
}

.hero-action {
  flex: none;
  min-width: 128rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 68rpx;
  text-align: center;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 14rpx 30rpx rgba(226, 49, 37, 0.22), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.28);
}

.hero-action[disabled] {
  color: rgba(255, 247, 237, 0.82);
  background: linear-gradient(135deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
}

.filter-scroll {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.status-filter-scroll {
  margin-top: 16rpx;
}

.filter-list {
  display: flex;
  gap: 14rpx;
  padding: 0 2rpx 4rpx;
}

.filter-tab {
  flex-shrink: 0;
  box-sizing: border-box;
  min-width: 116rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #7a6a5e;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  background: rgba(255, 250, 244, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 10rpx 22rpx rgba(126, 90, 45, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.filter-tab.active {
  color: #fff7ed;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  border-color: rgba(255, 255, 255, 0.34);
  box-shadow: 0 14rpx 28rpx rgba(226, 49, 37, 0.22), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.28);
}

.status-filter {
  min-width: 104rpx;
  height: 58rpx;
  line-height: 58rpx;
  font-size: 22rpx;
}

.state-card {
  margin-top: 28rpx;
  padding: 88rpx 40rpx;
  border-radius: 34rpx;
  text-align: center;
  color: #2c211d;
}

.state-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255, 111, 72, 0.14), rgba(255, 255, 255, 0.5));
}

.state-icon-image {
  display: block;
  width: 44rpx;
  height: 44rpx;
}

.state-title {
  color: #2a211d;
  font-size: 32rpx;
  font-weight: 900;
}

.state-desc {
  margin: 14rpx auto 0;
  max-width: 500rpx;
  color: #7a6a5e;
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 156rpx;
  height: 64rpx;
  margin-top: 28rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 14rpx 28rpx rgba(226, 49, 37, 0.22);
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 28rpx;
}

.dish-card {
  padding: 24rpx;
  border-radius: 30rpx;
  color: #2a211d;
}

.dish-card-muted {
  opacity: 0.86;
}

.dish-main {
  display: flex;
  gap: 20rpx;
}

.dish-image {
  flex: none;
  width: 150rpx;
  height: 150rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 28% 18%, rgba(255, 227, 180, 0.7), transparent 42%),
    linear-gradient(135deg, rgba(255, 250, 242, 0.96), rgba(247, 221, 202, 0.9));
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  box-shadow: 0 12rpx 26rpx rgba(126, 90, 45, 0.13);
}

.dish-image-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 248, 236, 0.92);
  font-size: 40rpx;
  font-weight: 900;
}

.dish-placeholder-image {
  width: 88rpx;
  height: 88rpx;
}

.dish-copy {
  min-width: 0;
  flex: 1;
}

.dish-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.dish-name {
  min-width: 0;
  color: #2a211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.28;
}

.dish-status {
  flex: none;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.status-on_sale {
  color: #4b8e33;
  background: #e8f6e8;
}

.status-off_sale {
  color: #9a6f6a;
  background: #f1e8e5;
}

.dish-desc {
  margin-top: 10rpx;
  color: #7a6a5e;
  font-size: 22rpx;
  line-height: 1.4;
}

.dish-meta,
.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.meta-pill,
.dish-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #7a6a5e;
  font-size: 20rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
}

.dish-tag {
  color: #e63b4a;
  background: #ffe8ec;
}

.stock-pill {
  color: #6b4a3d;
  background: rgba(255, 255, 255, 0.68);
}

.stock-unlimited {
  color: #4b8e33;
  background: #e8f6e8;
}

.stock-limited {
  color: #d87918;
  background: #fff1dd;
}

.stock-empty,
.stock-sold-out {
  color: #c9313c;
  background: #ffe9e5;
}

.dish-foot {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(126, 90, 45, 0.12);
}

.price-text {
  color: #e63b4a;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.original-price {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.42);
  font-size: 20rpx;
  text-decoration: line-through;
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.action-button {
  min-width: 104rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 12rpx 24rpx rgba(226, 49, 37, 0.2);
}

.action-button.ghost {
  color: #6b4a3d;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 8rpx 18rpx rgba(126, 90, 45, 0.07), inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.action-button.danger {
  color: #c9313c;
  background: rgba(255, 250, 244, 0.78);
  border: 1rpx solid rgba(201, 49, 60, 0.16);
  box-shadow: 0 8rpx 18rpx rgba(126, 90, 45, 0.07), inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.action-button[disabled] {
  color: rgba(107, 74, 61, 0.42);
  background: rgba(255, 255, 255, 0.42);
  box-shadow: none;
}

.form-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  background: rgba(43, 33, 27, 0.28);
  -webkit-backdrop-filter: blur(14px);
  backdrop-filter: blur(14px);
  box-sizing: border-box;
}

.dish-form {
  width: 100%;
  max-height: 86vh;
  padding: 28rpx;
  border-radius: 34rpx;
  color: #2a211d;
  box-sizing: border-box;
}

.form-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.form-kicker {
  color: #c9473f;
}

.form-title {
  margin-top: 6rpx;
  color: #2a211d;
  font-size: 34rpx;
  font-weight: 900;
}

.form-close {
  flex: none;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  color: rgba(42, 33, 29, 0.62);
  font-size: 42rpx;
  line-height: 54rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 8rpx 18rpx rgba(126, 90, 45, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.form-scroll {
  max-height: 58vh;
  margin-top: 22rpx;
}

.form-field {
  margin-top: 18rpx;
}

.field-label {
  color: rgba(42, 33, 29, 0.64);
  font-size: 22rpx;
  font-weight: 800;
}

.field-input,
.field-picker,
.field-textarea {
  width: 100%;
  min-height: 72rpx;
  margin-top: 10rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  color: #2a211d;
  font-size: 24rpx;
  line-height: 72rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.88), 0 6rpx 14rpx rgba(126, 90, 45, 0.05);
}

.field-textarea {
  height: 132rpx;
  padding-top: 18rpx;
  padding-bottom: 18rpx;
  line-height: 1.5;
}

.image-upload-card {
  margin-top: 10rpx;
  padding: 16rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72), 0 10rpx 24rpx rgba(126, 90, 45, 0.06);
}

.image-upload-preview,
.image-upload-placeholder {
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.image-upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(107, 74, 61, 0.68);
  background:
    radial-gradient(circle at 30% 22%, rgba(255, 219, 166, 0.6), transparent 34%),
    linear-gradient(135deg, rgba(255, 246, 232, 0.96) 0%, rgba(250, 218, 201, 0.92) 100%);
  border: 1rpx dashed rgba(230, 59, 74, 0.22);
}

.image-upload-placeholder-image {
  width: 78rpx;
  height: 78rpx;
  padding: 16rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 10rpx 20rpx rgba(230, 59, 74, 0.1);
}

.image-upload-title {
  margin-top: 18rpx;
  color: #2a211d;
  font-size: 26rpx;
  font-weight: 900;
}

.image-upload-desc {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.48);
  font-size: 22rpx;
}

.image-upload-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.image-upload-button {
  flex: none;
  min-width: 150rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 60rpx;
  text-align: center;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 12rpx 24rpx rgba(226, 49, 37, 0.2);
}

.image-upload-button[disabled] {
  color: rgba(255, 247, 237, 0.72);
  background: linear-gradient(135deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
}

.image-upload-tip {
  min-width: 0;
  color: rgba(42, 33, 29, 0.46);
  font-size: 21rpx;
  line-height: 1.35;
}

.form-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
}

.stock-panel {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.68), 0 10rpx 24rpx rgba(126, 90, 45, 0.06);
}

.stock-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.stock-panel-desc {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.48);
  font-size: 21rpx;
  line-height: 1.4;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(42, 33, 29, 0.08);
}

.switch-title {
  color: #2a211d;
  font-size: 25rpx;
  font-weight: 900;
}

.switch-desc {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.48);
  font-size: 21rpx;
  line-height: 1.35;
}

.stock-count-field {
  margin-top: 18rpx;
}

.option-panel {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.62);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.68), 0 10rpx 24rpx rgba(126, 90, 45, 0.06);
}

.option-panel-head,
.option-group-head,
.option-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.option-panel-desc {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.48);
  font-size: 21rpx;
  line-height: 1.4;
}

.option-add-button,
.option-remove-button,
.option-add-sub-button {
  flex: none;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 56rpx;
  text-align: center;
}

.option-add-button,
.option-add-sub-button {
  color: #fff7ed;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 12rpx 24rpx rgba(226, 49, 37, 0.18);
}

.option-add-sub-button {
  width: 100%;
  margin-top: 18rpx;
}

.option-remove-button {
  min-width: 96rpx;
  color: #c9313c;
  background: rgba(255, 250, 244, 0.78);
  border: 1rpx solid rgba(201, 49, 60, 0.16);
}

.option-remove-button.small {
  min-width: 84rpx;
  height: 50rpx;
  padding: 0 18rpx;
  font-size: 21rpx;
  line-height: 50rpx;
}

.option-empty {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  color: rgba(42, 33, 29, 0.52);
  font-size: 23rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.48);
}

.option-group-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 24rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.76), rgba(255, 248, 238, 0.56));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.88), 0 8rpx 20rpx rgba(126, 90, 45, 0.06);
}

.option-group-title,
.option-item-title {
  color: #2a211d;
  font-size: 25rpx;
  font-weight: 900;
}

.option-item-card {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.54);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.option-switch-row {
  margin-top: 16rpx;
}

.tutorial-panel {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.62);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.68), 0 10rpx 24rpx rgba(126, 90, 45, 0.06);
}

.tutorial-panel-head,
.tutorial-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.tutorial-panel-desc {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.48);
  font-size: 21rpx;
  line-height: 1.4;
}

.tutorial-add-button,
.tutorial-remove-button {
  flex: none;
  min-width: 112rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 56rpx;
  text-align: center;
}

.tutorial-add-button {
  color: #fff7ed;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 12rpx 24rpx rgba(226, 49, 37, 0.18);
}

.tutorial-add-button[disabled] {
  color: rgba(107, 74, 61, 0.42);
  background: rgba(255, 255, 255, 0.42);
  box-shadow: none;
}

.tutorial-empty {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  color: rgba(42, 33, 29, 0.52);
  font-size: 23rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.48);
