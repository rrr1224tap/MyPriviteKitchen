  margin-top: 24rpx;
}

.form-button {
  flex: 1;
  height: 76rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
}

.form-button.secondary {
  color: #6b4a3d;
  background: rgba(255, 255, 255, 0.74);
