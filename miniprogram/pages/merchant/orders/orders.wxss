page {
  min-height: 100%;
  background: #fbf3ea;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.merchant-orders-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #2b211b;
  background:
    radial-gradient(circle at 16% 0%, rgba(255, 255, 255, 0.94), transparent 270rpx),
    radial-gradient(circle at 88% 4%, rgba(255, 214, 162, 0.28), transparent 360rpx),
    linear-gradient(180deg, #fff7ed 0%, #f7efe6 55%, #fbf6ef 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 52vh;
  opacity: 0.08;
  filter: blur(8rpx) saturate(1.04);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 249, 241, 0.92) 0%, rgba(247, 239, 230, 0.86) 46%, rgba(251, 246, 239, 0.98) 100%),
    radial-gradient(circle at 50% 18%, rgba(255, 206, 145, 0.24), transparent 44%);
}

.custom-nav {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  left: 0;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  bottom: 10rpx;
  left: 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 50%;
  background: rgba(255, 250, 244, 0.72);
  box-shadow: 0 12rpx 28rpx rgba(126, 90, 45, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  pointer-events: auto;
  -webkit-backdrop-filter: blur(18px) saturate(145%);
  backdrop-filter: blur(18px) saturate(145%);
}

.nav-icon-image {
  display: block;
  width: 34rpx;
  height: 34rpx;
}

.nav-title {
  margin-bottom: 16rpx;
  color: #2b211b;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.orders-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.orders-content {
  padding: 0 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.glass-panel {
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(255, 248, 238, 0.64));
  box-shadow:
    0 20rpx 56rpx rgba(126, 90, 45, 0.13),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95),
    inset 0 -18rpx 42rpx rgba(255, 226, 191, 0.1);
  -webkit-backdrop-filter: blur(22px) saturate(150%);
  backdrop-filter: blur(22px) saturate(150%);
}

.merchant-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 34rpx;
}

.hero-kicker {
  color: #ef5a32;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 10rpx;
  color: #2b211b;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 10rpx;
  color: #7a6a5e;
  font-size: 23rpx;
  line-height: 1.45;
}

.hero-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(145deg, #ff9b39 0%, #ff6b2c 100%);
  box-shadow: 0 14rpx 30rpx rgba(240, 120, 34, 0.22), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.28);
  color: #fff7ed;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-scroll {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.filter-list {
  display: flex;
  gap: 14rpx;
  padding: 0 2rpx 4rpx;
}

.filter-tab {
  min-width: 116rpx;
  height: 64rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.72);
  box-shadow: 0 10rpx 22rpx rgba(126, 90, 45, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  color: #7a6a5e;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 64rpx;
  text-align: center;
}

.filter-tab.active {
  border-color: rgba(255, 255, 255, 0.34);
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 14rpx 28rpx rgba(226, 49, 37, 0.22), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.28);
  color: #fff7ed;
}

.state-card {
  margin-top: 28rpx;
  padding: 88rpx 40rpx;
  border-radius: 34rpx;
  text-align: center;
}

.state-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255, 111, 72, 0.14), rgba(255, 255, 255, 0.5));
}

.state-icon-image {
  display: block;
  width: 44rpx;
  height: 44rpx;
}

.state-title {
  color: #2a211d;
  font-size: 32rpx;
  font-weight: 900;
}

.state-desc {
  max-width: 500rpx;
  margin: 14rpx auto 0;
  color: #7a6a5e;
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 156rpx;
  height: 64rpx;
  margin-top: 28rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 14rpx 28rpx rgba(226, 49, 37, 0.22);
  color: #fff7ed;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 64rpx;
  text-align: center;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 28rpx;
}

.order-card {
  padding: 26rpx;
  border-radius: 32rpx;
  color: #2a211d;
}

.order-card-head,
.order-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.order-no {
  color: #2a211d;
  font-size: 27rpx;
  font-weight: 900;
}

.order-time {
  margin-top: 8rpx;
  color: #8a7668;
  font-size: 22rpx;
}

.status-tag {
  min-height: 46rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
}

.status-pending {
  color: #d87918;
  background: #fff1dd;
}

.status-accepted {
  color: #df4133;
  background: #ffe9e5;
}

.status-cooking {
  color: #f07822;
  background: #fff0dd;
}

.status-finished {
  color: #4b8e33;
  background: #e8f6e8;
}

.status-cancelled {
  color: #9a6f6a;
  background: #f1e8e5;
}

.order-summary {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.52);
  color: #69574c;
  font-size: 24rpx;
  line-height: 1.45;
}

.order-remark {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(230, 59, 74, 0.08);
  color: #6d584a;
  font-size: 23rpx;
  line-height: 1.45;
}

.remark-label {
  flex-shrink: 0;
  color: #ef3f38;
  font-weight: 800;
}

.order-card-foot {
  margin-top: 22rpx;
}

.order-count,
.order-total-label {
  color: #8a7668;
  font-size: 23rpx;
}

.order-total-label {
  margin-top: 6rpx;
  font-size: 20rpx;
}

.order-total {
  color: #ef3f38;
  font-size: 34rpx;
  font-weight: 900;
}

.action-row {
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(126, 90, 45, 0.12);
}

.action-button {
  min-width: 188rpx;
  height: 68rpx;
  box-sizing: border-box;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 14rpx 28rpx rgba(226, 49, 37, 0.22);
  color: #fff7ed;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 68rpx;
  text-align: center;
}

.action-button.is-danger {
  border: 1rpx solid rgba(201, 49, 60, 0.16);
  background: rgba(255, 250, 244, 0.78);
  box-shadow: 0 10rpx 22rpx rgba(126, 90, 45, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  color: #c9313c;
}

.action-button[disabled],
.action-button.is-submitting {
  background: linear-gradient(145deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
  color: rgba(255, 247, 237, 0.82);
}

.merchant-hero > view:first-child,
.order-card-head > view:first-child,
.order-remark > view:last-child,
.order-count {
  min-width: 0;
}

.hero-title,
.hero-desc,
.state-title,
.state-desc,
.order-no,
.order-time,
.order-summary,
.order-remark,
.order-count,
.order-total,
.order-total-label {
  overflow-wrap: anywhere;
}

.hero-desc,
.order-no,
.order-summary,
.order-remark {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.hero-desc,
.order-no,
.order-summary {
  -webkit-line-clamp: 2;
}

.order-remark {
  -webkit-line-clamp: 3;
}
