page {
  min-height: 100%;
  background: #211815;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.merchant-orders-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #f9efe4;
  background:
    radial-gradient(circle at 16% 0%, rgba(230, 59, 74, 0.22), transparent 34%),
    radial-gradient(circle at 84% 8%, rgba(255, 202, 128, 0.18), transparent 30%),
    linear-gradient(180deg, #2a1d18 0%, #16100e 52%, #f3e8dc 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 58vh;
  opacity: 0.24;
  filter: blur(1px);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(20, 13, 10, 0.68) 0%, rgba(26, 18, 15, 0.54) 34%, rgba(243, 232, 220, 0.97) 100%),
    radial-gradient(circle at 50% 42%, rgba(255, 229, 188, 0.18), transparent 42%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 50%;
  color: #fff6ea;
  font-size: 46rpx;
  font-weight: 300;
  line-height: 1;
  text-align: center;
  pointer-events: auto;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.18);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #fff3dc;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.orders-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.orders-content {
  padding: 0 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.glass-panel {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 18rpx 42rpx rgba(54, 24, 15, 0.18);
  backdrop-filter: blur(18px);
}

.merchant-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(62, 39, 30, 0.74);
}

.hero-kicker {
  color: rgba(255, 222, 169, 0.86);
  font-size: 20rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 8rpx;
  color: #fff8ec;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 8rpx;
  color: rgba(255, 246, 230, 0.72);
  font-size: 23rpx;
}

.hero-badge {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  color: #fff7ed;
  font-size: 24rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #ff6a72 0%, #e63b4a 100%);
  box-shadow: 0 14rpx 30rpx rgba(230, 59, 74, 0.3);
}

.filter-scroll {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.filter-list {
  display: flex;
  gap: 14rpx;
  padding: 0 2rpx 4rpx;
}

.filter-tab {
  flex-shrink: 0;
  box-sizing: border-box;
  min-width: 116rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: rgba(255, 246, 230, 0.78);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.08);
}

.filter-tab.active {
  color: #fff7ed;
  background: linear-gradient(135deg, #ff6a72 0%, #e63b4a 100%);
  border-color: rgba(255, 255, 255, 0.24);
  box-shadow: 0 14rpx 28rpx rgba(230, 59, 74, 0.3);
}

.state-card {
  margin-top: 28rpx;
  padding: 88rpx 40rpx;
  border-radius: 34rpx;
  text-align: center;
  background: rgba(255, 249, 240, 0.8);
  color: #2c211d;
}

.state-mark {
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 50%;
  color: #e63b4a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: inset 0 0 0 1rpx rgba(230, 59, 74, 0.12);
}

.state-title {
  color: #2a211d;
  font-size: 32rpx;
  font-weight: 800;
}

.state-desc {
  margin: 14rpx auto 0;
  max-width: 500rpx;
  color: rgba(42, 33, 29, 0.58);
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  display: inline-block;
  min-width: 156rpx;
  height: 64rpx;
  margin-top: 28rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff6a72 0%, #e63b4a 100%);
  box-shadow: 0 14rpx 28rpx rgba(230, 59, 74, 0.34);
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 28rpx;
}

.order-card {
  padding: 26rpx;
  border-radius: 30rpx;
  background: rgba(255, 250, 244, 0.86);
  color: #2a211d;
  box-shadow: 0 18rpx 38rpx rgba(68, 36, 23, 0.12);
}

.order-card-head,
.order-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.order-no {
  color: #2a211d;
  font-size: 27rpx;
  font-weight: 800;
}

.order-time {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.5);
  font-size: 22rpx;
}

.status-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status-pending {
  color: #d87918;
  background: #fff1dd;
}

.status-accepted {
  color: #2f72cf;
  background: #e8f1ff;
}

.status-cooking {
  color: #e63b4a;
  background: #ffe8ec;
}

.status-finished {
  color: #4b8e33;
  background: #e8f6e8;
}

.status-cancelled {
  color: #777;
  background: #eeeeee;
}

.order-summary {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  color: rgba(42, 33, 29, 0.76);
  font-size: 24rpx;
  line-height: 1.45;
  background: rgba(255, 255, 255, 0.58);
}

.order-remark {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  color: rgba(42, 33, 29, 0.7);
  font-size: 23rpx;
  line-height: 1.45;
  background: rgba(230, 59, 74, 0.08);
}

.remark-label {
  flex-shrink: 0;
  color: #e63b4a;
  font-weight: 800;
}

.order-card-foot {
  margin-top: 22rpx;
}

.order-count,
.order-total-label {
  color: rgba(42, 33, 29, 0.5);
  font-size: 23rpx;
}

.order-total-label {
  margin-top: 6rpx;
  font-size: 20rpx;
}

.order-total {
  color: #e63b4a;
  font-size: 34rpx;
  font-weight: 900;
}

.action-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(42, 33, 29, 0.08);
}

.action-button {
  min-width: 188rpx;
  height: 68rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 68rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff6a72 0%, #e63b4a 100%);
  box-shadow: 0 14rpx 28rpx rgba(230, 59, 74, 0.3);
}

.action-button[disabled] {
  color: rgba(255, 247, 237, 0.82);
  background: linear-gradient(135deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
}

.action-button.is-submitting {
  color: rgba(255, 247, 237, 0.82);
  background: linear-gradient(135deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
}

.merchant-hero > view:first-child,
.order-card-head > view:first-child,
.order-remark > view:last-child,
.order-count {
  min-width: 0;
}

.hero-title,
.hero-desc,
.state-title,
.state-desc,
.order-no,
.order-time,
.order-summary,
.order-remark,
.order-count,
.order-total,
.order-total-label {
  overflow-wrap: anywhere;
}

.hero-desc,
.order-no,
.order-summary,
.order-remark {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.hero-desc,
.order-no,
.order-summary {
  -webkit-line-clamp: 2;
}

.order-remark {
  -webkit-line-clamp: 3;
}

.hero-badge,
.filter-tab,
.state-button,
.status-tag,
.action-button {
  box-sizing: border-box;
}

.status-tag {
  min-height: 46rpx;
  line-height: 1.2;
  text-align: center;
}
