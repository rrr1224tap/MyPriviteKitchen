page {
  min-height: 100%;
  background: #211815;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.merchant-categories-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #fffaf4;
  background:
    radial-gradient(circle at 16% 0%, rgba(230, 59, 74, 0.22), transparent 34%),
    radial-gradient(circle at 84% 8%, rgba(255, 202, 128, 0.18), transparent 30%),
    linear-gradient(180deg, #2a1d18 0%, #16100e 52%, #f3e8dc 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 58vh;
  opacity: 0.24;
  filter: blur(1px);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(20, 13, 10, 0.68) 0%, rgba(26, 18, 15, 0.54) 34%, rgba(243, 232, 220, 0.97) 100%),
    radial-gradient(circle at 50% 42%, rgba(255, 229, 188, 0.18), transparent 42%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 50%;
  color: #fff6ea;
  font-family: serif;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  text-align: center;
  pointer-events: auto;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.18);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #fff3dc;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.categories-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.categories-content {
  padding: 0 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.glass-panel {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 18rpx 42rpx rgba(54, 24, 15, 0.18);
  backdrop-filter: blur(18px);
}

.warm-glass {
  background: rgba(255, 250, 244, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 16rpx 38rpx rgba(61, 39, 25, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18px);
}

.merchant-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  background: rgba(62, 39, 30, 0.74);
}

.hero-copy {
  min-width: 0;
}

.hero-kicker {
  color: rgba(255, 222, 169, 0.86);
  font-size: 20rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 8rpx;
  color: #fff8ec;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 8rpx;
  color: rgba(255, 246, 230, 0.72);
  font-size: 23rpx;
  line-height: 1.45;
}

.hero-action {
  flex: none;
  min-width: 128rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 68rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff6a72 0%, #e63b4a 100%);
  box-shadow: 0 14rpx 30rpx rgba(230, 59, 74, 0.34);
}

.hero-action[disabled] {
  color: rgba(255, 247, 237, 0.82);
  background: linear-gradient(135deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
}

.state-card {
  margin-top: 28rpx;
  padding: 88rpx 40rpx;
  border-radius: 34rpx;
  text-align: center;
  color: #2c211d;
}

.state-mark {
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 50%;
  color: #e63b4a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: inset 0 0 0 1rpx rgba(230, 59, 74, 0.12);
}

.state-title {
  color: #2a211d;
  font-size: 32rpx;
  font-weight: 800;
}

.state-desc {
  margin: 14rpx auto 0;
  max-width: 500rpx;
  color: rgba(42, 33, 29, 0.58);
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  display: inline-block;
  min-width: 156rpx;
  height: 64rpx;
  margin-top: 28rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff6a72 0%, #e63b4a 100%);
  box-shadow: 0 14rpx 28rpx rgba(230, 59, 74, 0.34);
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 28rpx;
}

.category-card {
  padding: 26rpx;
  border-radius: 30rpx;
  color: #2a211d;
}

.category-card-muted {
  opacity: 0.78;
}

.category-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.category-name-wrap {
  min-width: 0;
  flex: 1;
}

.category-name {
  color: #2a211d;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.3;
}

.category-id {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.42);
  font-size: 20rpx;
  line-height: 1.3;
  word-break: break-all;
}

.category-status {
  flex: none;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status-active {
  color: #4b8e33;
  background: #e8f6e8;
}

.status-inactive {
  color: #777;
  background: #eeeeee;
}

.status-deleted {
  color: #8a5f20;
  background: #fff1dd;
}

.category-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.meta-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: rgba(42, 33, 29, 0.64);
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.58);
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(42, 33, 29, 0.08);
}

.action-button {
  min-width: 112rpx;
  height: 62rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 62rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff6a72 0%, #e63b4a 100%);
  box-shadow: 0 12rpx 24rpx rgba(230, 59, 74, 0.26);
}

.action-button.ghost {
  color: #6b4a3d;
  background: rgba(255, 255, 255, 0.64);
  box-shadow: none;
}

.action-button.danger {
  color: #e63b4a;
  background: #ffe8ec;
  box-shadow: none;
}

.action-button[disabled] {
  color: rgba(107, 74, 61, 0.42);
  background: rgba(255, 255, 255, 0.42);
  box-shadow: none;
}
