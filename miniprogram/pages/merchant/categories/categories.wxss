page {
  min-height: 100%;
  background: #fbf3ea;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.merchant-categories-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #2b211b;
  background:
    radial-gradient(circle at 16% 0%, rgba(255, 255, 255, 0.94), transparent 270rpx),
    radial-gradient(circle at 88% 4%, rgba(255, 214, 162, 0.28), transparent 360rpx),
    linear-gradient(180deg, #fff7ed 0%, #f7efe6 55%, #fbf6ef 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 52vh;
  opacity: 0.08;
  filter: blur(8rpx) saturate(1.04);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 249, 241, 0.92) 0%, rgba(247, 239, 230, 0.86) 46%, rgba(251, 246, 239, 0.98) 100%),
    radial-gradient(circle at 50% 18%, rgba(255, 206, 145, 0.24), transparent 44%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 50%;
  color: #6d584a;
  font-family: serif;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  text-align: center;
  pointer-events: auto;
  background: rgba(255, 250, 244, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 28rpx rgba(126, 90, 45, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  -webkit-backdrop-filter: blur(18px) saturate(145%);
  backdrop-filter: blur(18px) saturate(145%);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #2b211b;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.categories-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.categories-content {
  padding: 0 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.glass-panel,
.warm-glass {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(255, 248, 238, 0.64));
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow:
    0 20rpx 56rpx rgba(126, 90, 45, 0.13),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95),
    inset 0 -18rpx 42rpx rgba(255, 226, 191, 0.1);
  -webkit-backdrop-filter: blur(22px) saturate(150%);
  backdrop-filter: blur(22px) saturate(150%);
}

.merchant-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 34rpx;
}

.hero-copy {
  min-width: 0;
}

.hero-kicker {
  color: #ef5a32;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 8rpx;
  color: #2b211b;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 8rpx;
  color: #7a6a5e;
  font-size: 23rpx;
  line-height: 1.45;
}

.hero-action {
  flex: none;
  min-width: 128rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 68rpx;
  text-align: center;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 14rpx 30rpx rgba(226, 49, 37, 0.22), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.28);
}

.hero-action[disabled] {
  color: rgba(255, 247, 237, 0.82);
  background: linear-gradient(135deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
}

.state-card {
  margin-top: 28rpx;
  padding: 88rpx 40rpx;
  border-radius: 34rpx;
  text-align: center;
  color: #2c211d;
}

.state-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255, 111, 72, 0.14), rgba(255, 255, 255, 0.5));
}

.state-icon-image {
  display: block;
  width: 44rpx;
  height: 44rpx;
}

.state-title {
  color: #2a211d;
  font-size: 32rpx;
  font-weight: 900;
}

.state-desc {
  margin: 14rpx auto 0;
  max-width: 500rpx;
  color: #7a6a5e;
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 156rpx;
  height: 64rpx;
  margin-top: 28rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 14rpx 28rpx rgba(226, 49, 37, 0.22);
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 28rpx;
}

.category-card {
  padding: 26rpx;
  border-radius: 30rpx;
  color: #2a211d;
}

.category-card-muted {
  opacity: 0.86;
}

.category-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.category-name-wrap {
  min-width: 0;
  flex: 1;
}

.category-name {
  color: #2a211d;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.3;
}

.category-id {
  margin-top: 8rpx;
  color: #8a7668;
  font-size: 20rpx;
  line-height: 1.3;
  word-break: break-all;
}

.category-status {
  flex: none;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status-active {
  color: #4b8e33;
  background: #e8f6e8;
}

.status-inactive {
  color: #9a6f6a;
  background: #f1e8e5;
}

.status-deleted {
  color: #d87918;
  background: #fff1dd;
}

.category-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.meta-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #7a6a5e;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(126, 90, 45, 0.12);
}

.action-button {
  min-width: 112rpx;
  height: 62rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 62rpx;
  text-align: center;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 12rpx 24rpx rgba(226, 49, 37, 0.2);
}

.action-button.ghost {
  color: #6b4a3d;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 8rpx 18rpx rgba(126, 90, 45, 0.07), inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.action-button.danger {
  color: #c9313c;
  background: rgba(255, 250, 244, 0.78);
  border: 1rpx solid rgba(201, 49, 60, 0.16);
  box-shadow: 0 8rpx 18rpx rgba(126, 90, 45, 0.07), inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.action-button[disabled] {
  color: rgba(107, 74, 61, 0.42);
  background: rgba(255, 255, 255, 0.42);
  box-shadow: none;
}
