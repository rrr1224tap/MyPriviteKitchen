page {
  min-height: 100%;
  background: #fbf3ea;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.merchant-order-detail-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #2b211b;
  background:
    radial-gradient(circle at 16% 0%, rgba(255, 255, 255, 0.94), transparent 270rpx),
    radial-gradient(circle at 88% 4%, rgba(255, 214, 162, 0.28), transparent 360rpx),
    linear-gradient(180deg, #fff7ed 0%, #f7efe6 55%, #fbf6ef 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 52vh;
  opacity: 0.08;
  filter: blur(8rpx) saturate(1.04);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 249, 241, 0.92) 0%, rgba(247, 239, 230, 0.86) 46%, rgba(251, 246, 239, 0.98) 100%),
    radial-gradient(circle at 50% 18%, rgba(255, 206, 145, 0.24), transparent 44%);
}

.custom-nav {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  left: 0;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  bottom: 10rpx;
  left: 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 50%;
  background: rgba(255, 250, 244, 0.72);
  box-shadow: 0 12rpx 28rpx rgba(126, 90, 45, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  pointer-events: auto;
  -webkit-backdrop-filter: blur(18px) saturate(145%);
  backdrop-filter: blur(18px) saturate(145%);
}

.nav-icon-image {
  display: block;
  width: 34rpx;
  height: 34rpx;
}

.nav-title {
  margin-bottom: 16rpx;
  color: #2b211b;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.detail-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.detail-content {
  padding: 0 28rpx calc(52rpx + env(safe-area-inset-bottom));
}

.detail-content.has-action {
  padding-bottom: calc(174rpx + env(safe-area-inset-bottom));
}

.glass-panel,
.warm-glass {
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(255, 248, 238, 0.64));
  box-shadow:
    0 20rpx 56rpx rgba(126, 90, 45, 0.13),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95),
    inset 0 -18rpx 42rpx rgba(255, 226, 191, 0.1);
  color: #2b201a;
  -webkit-backdrop-filter: blur(22px) saturate(150%);
  backdrop-filter: blur(22px) saturate(150%);
}

.detail-hero,
.remark-panel,
.items-panel,
.info-panel,
.total-panel,
.state-card {
  box-sizing: border-box;
  border-radius: 32rpx;
}

.detail-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding: 30rpx;
}

.hero-kicker,
.section-kicker {
  color: #ef5a32;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 8rpx;
  color: #2b211b;
  font-size: 44rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 10rpx;
  color: #7a6a5e;
  font-size: 23rpx;
}

.hero-time {
  margin-top: 8rpx;
  color: #8a7668;
  font-size: 21rpx;
}

.status-tag {
  min-height: 46rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  padding: 11rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
}

.status-pending {
  color: #d87918;
  background: #fff1dd;
}

.status-accepted {
  color: #df4133;
  background: #ffe9e5;
}

.status-cooking {
  color: #f07822;
  background: #fff0dd;
}

.status-finished {
  color: #4b8e33;
  background: #e8f6e8;
}

.status-cancelled {
  color: #9a6f6a;
  background: #f1e8e5;
}

.remark-panel,
.items-panel,
.info-panel,
.total-panel {
  margin-top: 22rpx;
  padding: 28rpx;
}

.section-head,
.total-panel,
.order-item,
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  margin-top: 6rpx;
  color: #2b211b;
  font-size: 30rpx;
  font-weight: 800;
}

.section-kicker.is-dark,
.section-title.is-dark {
  color: #2b201a;
}

.section-kicker.is-dark {
  color: #ef5a32;
}

.remark-content {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.52);
  color: #6d584a;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.55;
}

.item-count {
  min-height: 46rpx;
  box-sizing: border-box;
  padding: 9rpx 15rpx;
  border-radius: 999rpx;
  background: rgba(230, 59, 74, 0.1);
  color: #d7353f;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
}

.order-item {
  margin-top: 22rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(126, 90, 45, 0.12);
}

.dish-emblem {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  flex: none;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 10rpx 20rpx rgba(226, 49, 37, 0.18);
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.dish-info {
  min-width: 0;
  flex: 1;
}

.dish-name {
  color: #2a211d;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.dish-price {
  margin-top: 8rpx;
  color: #8a7668;
  font-size: 21rpx;
}

.dish-options {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 8rpx;
}

.dish-option-line {
  color: #7a6a5e;
  font-size: 20rpx;
  line-height: 1.35;
}

.dish-side {
  max-width: 180rpx;
  flex: none;
  text-align: right;
}

.dish-quantity {
  color: #8a7668;
  font-size: 22rpx;
}

.dish-subtotal {
  margin-top: 8rpx;
  color: #ef3f38;
  font-size: 27rpx;
  font-weight: 900;
}

.empty-items {
  margin-top: 24rpx;
  padding: 36rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.52);
  color: #8a7668;
  font-size: 24rpx;
  text-align: center;
}

.info-row {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.52);
}

.info-label {
  color: #8a7668;
  font-size: 22rpx;
}

.info-value {
  max-width: 430rpx;
  color: #2b211b;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
  text-align: right;
}

.total-panel {
  min-height: 128rpx;
}

.total-label {
  color: #2b211b;
  font-size: 28rpx;
  font-weight: 800;
}

.total-note {
  margin-top: 8rpx;
  color: #8a7668;
  font-size: 19rpx;
}

.total-price {
  color: #ef3f38;
  font-size: 42rpx;
  font-weight: 900;
}

.fixed-action-bar {
  position: fixed;
  z-index: 30;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(251, 246, 239, 0), rgba(251, 246, 239, 0.88) 30%, rgba(251, 246, 239, 0.96) 100%);
  -webkit-backdrop-filter: blur(18px) saturate(150%);
  backdrop-filter: blur(18px) saturate(150%);
}

.action-button,
.state-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  flex: 1;
  min-width: 0;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ff6640 0%, #ef3f38 100%);
  box-shadow: 0 14rpx 28rpx rgba(226, 49, 37, 0.22);
  color: #fff7ed;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 78rpx;
}

.action-button.is-danger {
  border: 1rpx solid rgba(201, 49, 60, 0.16);
  background: rgba(255, 250, 244, 0.78);
  box-shadow: 0 10rpx 22rpx rgba(126, 90, 45, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  color: #c9313c;
}

.action-button[disabled],
.action-button.is-submitting {
  background: linear-gradient(145deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
  color: rgba(255, 247, 237, 0.82);
}

.state-card {
  margin-top: 120rpx;
  padding: 88rpx 40rpx;
  text-align: center;
}

.state-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255, 111, 72, 0.14), rgba(255, 255, 255, 0.5));
}

.state-icon-image {
  display: block;
  width: 44rpx;
  height: 44rpx;
}

.state-title {
  color: #2a211d;
  font-size: 32rpx;
  font-weight: 900;
}

.state-desc {
  max-width: 500rpx;
  margin: 14rpx auto 0;
  color: #7a6a5e;
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  width: 240rpx;
  margin: 30rpx auto 0;
}

.state-actions {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 30rpx;
}

.state-actions .state-button {
  margin: 0;
}

.state-button.is-secondary {
  border: 1rpx solid rgba(126, 90, 45, 0.14);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 10rpx 22rpx rgba(126, 90, 45, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  color: #7c5848;
}

.detail-hero > view:first-child,
.section-head > view:first-child,
.info-value {
  min-width: 0;
}

.hero-title,
.hero-desc,
.hero-time,
.section-title,
.remark-content,
.dish-name,
.dish-option-line,
.dish-price,
.dish-subtotal,
.empty-items,
.info-value,
.total-note,
.total-price,
.state-title,
.state-desc {
  overflow-wrap: anywhere;
}

.hero-desc,
.dish-name,
.dish-option-line {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.hero-desc,
.dish-name {
  -webkit-line-clamp: 2;
}

.dish-option-line {
  -webkit-line-clamp: 2;
}

.action-button,
.state-button,
.info-row {
  box-sizing: border-box;
}
