page {
  min-height: 100%;
  background: #211815;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.merchant-order-detail-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #fffaf4;
  background:
    radial-gradient(circle at 15% 0%, rgba(230, 59, 74, 0.2), transparent 34%),
    radial-gradient(circle at 84% 8%, rgba(255, 202, 128, 0.18), transparent 30%),
    linear-gradient(180deg, #2a1d18 0%, #17100e 54%, #f1e8de 100%);
}

.background-image-window {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 58vh;
  opacity: 0.25;
  filter: blur(1px);
}

.background-shade {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(20, 13, 10, 0.66) 0%, rgba(26, 18, 15, 0.54) 36%, rgba(241, 232, 222, 0.96) 100%),
    radial-gradient(circle at 50% 40%, rgba(255, 229, 188, 0.16), transparent 42%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  max-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  color: #fff6ea;
  font-family: serif;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  pointer-events: auto;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.18);
}

.nav-title {
  margin-bottom: 16rpx;
  color: #fff3dc;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.detail-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.detail-content {
  padding: 0 28rpx calc(52rpx + env(safe-area-inset-bottom));
}

.detail-content.has-action {
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
}

.glass-panel {
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  background: rgba(61, 48, 41, 0.72);
  box-shadow: 0 18rpx 42rpx rgba(54, 24, 15, 0.18), inset 0 2rpx 0 rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(18px);
}

.warm-glass {
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  background: rgba(255, 250, 244, 0.88);
  color: #2b201a;
  box-shadow: 0 16rpx 38rpx rgba(61, 39, 25, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18px);
}

.detail-hero,
.remark-panel,
.items-panel,
.info-panel,
.total-panel,
.state-card {
  box-sizing: border-box;
  border-radius: 32rpx;
}

.detail-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding: 30rpx;
}

.hero-kicker,
.section-kicker {
  color: #d1ad72;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.hero-title {
  margin-top: 8rpx;
  color: #fff8ec;
  font-size: 44rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 10rpx;
  color: rgba(255, 246, 230, 0.72);
  font-size: 23rpx;
}

.hero-time {
  margin-top: 8rpx;
  color: rgba(255, 246, 230, 0.52);
  font-size: 21rpx;
}

.status-tag {
  flex-shrink: 0;
  padding: 11rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status-pending {
  color: #d87918;
  background: #fff1dd;
}

.status-accepted {
  color: #2f72cf;
  background: #e8f1ff;
}

.status-cooking {
  color: #e63b4a;
  background: #ffe8ec;
}

.status-finished {
  color: #4b8e33;
  background: #e8f6e8;
}

.status-cancelled {
  color: #777;
  background: #eeeeee;
}

.remark-panel,
.items-panel,
.info-panel,
.total-panel {
  margin-top: 22rpx;
  padding: 28rpx;
}

.section-head,
.total-panel,
.order-item,
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  margin-top: 6rpx;
  color: #fffaf4;
  font-size: 30rpx;
  font-weight: 800;
}

.section-kicker.is-dark,
.section-title.is-dark {
  color: #2b201a;
}

.section-kicker.is-dark {
  color: #b17839;
}

.remark-content {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  color: rgba(255, 250, 244, 0.9);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.55;
  background: rgba(255, 255, 255, 0.1);
}

.item-count {
  padding: 9rpx 15rpx;
  border-radius: 999rpx;
  color: #d7353f;
  font-size: 20rpx;
  font-weight: 700;
  background: rgba(230, 59, 74, 0.1);
}

.order-item {
  margin-top: 22rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(82, 53, 35, 0.08);
}

.dish-emblem {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  flex: none;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #f2494e, #bd111b);
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.dish-info {
  min-width: 0;
  flex: 1;
}

.dish-name {
  color: #2a211d;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.dish-price {
  margin-top: 8rpx;
  color: rgba(42, 33, 29, 0.5);
  font-size: 21rpx;
}

.dish-options {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 8rpx;
}

.dish-option-line {
  color: rgba(42, 33, 29, 0.58);
  font-size: 20rpx;
  line-height: 1.35;
}

.dish-side {
  flex: none;
  text-align: right;
}

.dish-quantity {
  color: rgba(42, 33, 29, 0.48);
  font-size: 22rpx;
}

.dish-subtotal {
  margin-top: 8rpx;
  color: #e63b4a;
  font-size: 27rpx;
  font-weight: 900;
}

.empty-items {
  margin-top: 24rpx;
  padding: 36rpx;
  border-radius: 24rpx;
  color: rgba(42, 33, 29, 0.48);
  font-size: 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.54);
}

.info-row {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.09);
}

.info-label {
  color: rgba(255, 255, 255, 0.48);
  font-size: 22rpx;
}

.info-value {
  max-width: 430rpx;
  color: rgba(255, 250, 244, 0.9);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
  text-align: right;
}

.total-panel {
  min-height: 128rpx;
}

.total-label {
  color: #fffaf4;
  font-size: 28rpx;
  font-weight: 800;
}

.total-note {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.48);
  font-size: 19rpx;
}

.total-price {
  color: #ff5055;
  font-size: 42rpx;
  font-weight: 900;
}

.fixed-action-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(37, 26, 22, 0), rgba(37, 26, 22, 0.88) 34%, rgba(37, 26, 22, 0.96));
}

.action-button,
.state-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  height: 78rpx;
  border-radius: 999rpx;
  color: #fff7ed;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 78rpx;
  background: linear-gradient(135deg, #ff6a72 0%, #e63b4a 100%);
  box-shadow: 0 14rpx 28rpx rgba(230, 59, 74, 0.32);
}

.action-button.is-danger {
  color: #ffdce0;
  background: rgba(255, 255, 255, 0.12);
  box-shadow: inset 0 0 0 1rpx rgba(255, 220, 224, 0.24);
}

.action-button[disabled] {
  color: rgba(255, 247, 237, 0.82);
  background: linear-gradient(135deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
}

.action-button.is-submitting {
  color: rgba(255, 247, 237, 0.82);
  background: linear-gradient(135deg, #d8a2a4 0%, #b97b80 100%);
  box-shadow: none;
}

.state-card {
  margin-top: 120rpx;
  padding: 88rpx 40rpx;
  text-align: center;
  background: rgba(255, 249, 240, 0.78);
  color: #2c211d;
}

.state-mark {
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 50%;
  color: #e63b4a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: inset 0 0 0 1rpx rgba(230, 59, 74, 0.12);
}

.state-title {
  color: #2a211d;
  font-size: 32rpx;
  font-weight: 800;
}

.state-desc {
  margin: 14rpx auto 0;
  max-width: 500rpx;
  color: rgba(42, 33, 29, 0.58);
  font-size: 24rpx;
  line-height: 1.55;
}

.state-button {
  width: 240rpx;
  margin: 30rpx auto 0;
}

.state-actions {
  display: flex;
  justify-content: center;
  gap: 18rpx;
  margin-top: 30rpx;
}

.state-actions .state-button {
  margin: 0;
}

.state-button.is-secondary {
  color: #7c5848;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: inset 0 0 0 1rpx rgba(124, 88, 72, 0.12);
}

.detail-hero > view:first-child,
.section-head > view:first-child,
.info-value {
  min-width: 0;
}

.hero-title,
.hero-desc,
.hero-time,
.section-title,
.remark-content,
.dish-name,
.dish-option-line,
.dish-price,
.dish-subtotal,
.empty-items,
.info-value,
.total-note,
.total-price,
.state-title,
.state-desc {
  overflow-wrap: anywhere;
}

.hero-desc,
.dish-name,
.dish-option-line {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.hero-desc,
.dish-name {
  -webkit-line-clamp: 2;
}

.dish-option-line {
  -webkit-line-clamp: 2;
}

.dish-side {
  max-width: 180rpx;
}

.status-tag,
.item-count,
.action-button,
.state-button,
.info-row {
  box-sizing: border-box;
}

.status-tag,
.item-count {
  min-height: 46rpx;
  line-height: 1.2;
  text-align: center;
}

.state-actions {
  flex-wrap: wrap;
}
