.empty-state {
  box-sizing: border-box;
  padding: 96rpx 32rpx;
  text-align: center;
}

.empty-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 24rpx;
  border-radius: 50%;
  background: #fff0f2;
  color: #e63b4a;
  font-size: 44rpx;
  font-weight: bold;
}

.empty-title {
  color: #171717;
  font-size: 30rpx;
  font-weight: bold;
}

.empty-desc {
  margin-top: 12rpx;
  color: #aaaaaa;
  font-size: 24rpx;
  line-height: 1.6;
}

.empty-button {
  margin-top: 28rpx;
  padding: 0 34rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #e63b4a;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 64rpx;
  box-shadow: 0 8rpx 20rpx rgba(230, 59, 74, 0.22);
}

.empty-button::after {
  border: none;
}
