.order-card {
  box-sizing: border-box;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.order-header,
.order-footer,
.order-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-no {
  color: #171717;
  font-size: 30rpx;
  font-weight: bold;
}

.order-info {
  margin-top: 16rpx;
  color: #777777;
  font-size: 26rpx;
  line-height: 1.6;
}

.order-summary {
  color: #171717;
  font-weight: 500;
}

.order-remark {
  margin-top: 8rpx;
  box-sizing: border-box;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #fff8ef;
  color: #d85a42;
  font-size: 24rpx;
}

.order-time {
  margin-top: 8rpx;
  color: #aaaaaa;
  font-size: 24rpx;
}

.order-footer {
  margin-top: 18rpx;
}

.order-count {
  color: #777777;
  font-size: 26rpx;
}

.order-amount {
  color: #171717;
  font-size: 36rpx;
  font-weight: bold;
}

.order-actions {
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-button {
  margin: 0;
  padding: 0 28rpx;
  height: 60rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 60rpx;
}

.action-button::after {
  border: none;
}

.action-primary {
  background: #e63b4a;
  box-shadow: 0 8rpx 20rpx rgba(230, 59, 74, 0.22);
}

.action-secondary {
  background: #fff0f2;
  color: #e63b4a;
  box-shadow: none;
}
